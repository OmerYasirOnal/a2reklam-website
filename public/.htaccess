# A2 REKLAM - PRODUCTION HTACCESS
# ================================================

Options -MultiViews

# ================================================
# LEGACY WORDPRESS REDIRECTS
# ================================================
<IfModule mod_alias.c>
  # -- Sitemap eski yollar --
  Redirect 301 /sitemap.xml /sitemap-index.xml
  Redirect 301 /sitemap_index.xml /sitemap-index.xml
  Redirect 301 /post-sitemap.xml /sitemap-0.xml
  Redirect 301 /page-sitemap.xml /sitemap-0.xml

  # -- Statik sayfa eski yollar --
  Redirect 301 /iletisim-tabela/ /iletisim/
  Redirect 301 /hakkinda/ /hakkimizda/
  Redirect 301 /tabela-cesitleri/ /hizmetler/
  Redirect 301 /teklif-al/ /iletisim/

  # -- Eski "-tabelaci" sonekli ilce URL'leri (regex yakalamiyor) --
  Redirect 301 /uskudar-tabela-tabelaci/ /hizmet-bolgeleri/uskudar-tabela/
  Redirect 301 /sisli-tabela-tabelaci/ /hizmet-bolgeleri/sisli-tabela/
  Redirect 301 /kadikoy-tabela-tabelaci/ /hizmet-bolgeleri/kadikoy-tabela/
  Redirect 301 /besiktas-tabela-tabelaci/ /hizmet-bolgeleri/besiktas-tabela/
  Redirect 301 /beyoglu-tabela-tabelaci/ /hizmet-bolgeleri/beyoglu-tabela/
  Redirect 301 /fatih-tabela-tabelaci/ /hizmet-bolgeleri/fatih-tabela/
  Redirect 301 /bakirkoy-tabela-tabelaci/ /hizmet-bolgeleri/bakirkoy-tabela/
  Redirect 301 /umraniye-tabela-tabelaci/ /hizmet-bolgeleri/umraniye-tabela/
  Redirect 301 /atasehir-tabela-tabelaci/ /hizmet-bolgeleri/atasehir-tabela/
  Redirect 301 /maltepe-tabela-tabelaci/ /hizmet-bolgeleri/maltepe-tabela/

  # -- Eski blog yazilar --
  Redirect 301 /fener-tabela-nedir/ /hizmetler/fener-tabela/

  # -- Eski /tabelacesitleri/ hizmet URL'leri --
  Redirect 301 /tabelacesitleri/folyo-baski-uygulama/ /hizmetler/ofis-kumlama-folyolari/
  Redirect 301 /tabelacesitleri/pleksi-kutu-harf/ /hizmetler/kabartma-pleksiglass/
  Redirect 301 /tabelacesitleri/kutu-harf/ /hizmetler/paslanmaz-harfler/
  Redirect 301 /tabelacesitleri/isikli-tabela/ /hizmetler/isikli-tabela/
  Redirect 301 /tabelacesitleri/totem-tabela/ /hizmetler/totem/
  Redirect 301 /tabelacesitleri/cephe-tabela/ /hizmetler/cephe-tabela/
  Redirect 301 /tabelacesitleri/arac-giydirme/ /hizmetler/arac-giydirme/
  Redirect 301 /tabelacesitleri/paslanmaz-harf/ /hizmetler/paslanmaz-harfler/
  Redirect 301 /tabelacesitleri/dijital-baski/ /hizmetler/
  Redirect 301 /tabelacesitleri/neon-tabela/ /hizmetler/isikli-tabela/

  # -- Standart ilce slug'lari (regex ile) --
  RedirectMatch 301 ^/([a-z0-9-]+-tabela)/?$ /hizmet-bolgeleri/$1/
</IfModule>

# ================================================
# REMOVED LANGUAGE & PROVINCE REDIRECTS
# ================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # -- /ar/ catch-all → Turkce ana sayfa --
  RewriteRule ^ar/?$ / [R=301,L]
  RewriteRule ^ar/services/?$ /hizmetler/ [R=301,L]
  RewriteRule ^ar/gallery/?$ /galeri/ [R=301,L]
  RewriteRule ^ar/contact/?$ /iletisim/ [R=301,L]
  RewriteRule ^ar/get-quote/?$ /iletisim/ [R=301,L]
  RewriteRule ^ar/about/?$ /hakkimizda/ [R=301,L]
  RewriteRule ^ar/(.*)$ / [R=301,L]

  # -- /en/ silinen sayfalar → Turkce karsiliklari --
  RewriteRule ^en/service-areas/?$ /hizmet-bolgeleri/ [R=301,L]
  RewriteRule ^en/service-areas/([a-z0-9-]+)-tabela/?$ /hizmet-bolgeleri/$1-tabela/ [R=301,L]
  RewriteRule ^en/services/([a-z0-9-]+)/?$ /hizmetler/$1/ [R=301,L]
  RewriteRule ^en/blog/?$ /blog/ [R=301,L]
  RewriteRule ^en/blog/(.+)/?$ /blog/ [R=301,L]
  RewriteRule ^en/faq/?$ /sss/ [R=301,L]
  RewriteRule ^en/thank-you/?$ /tesekkurler/ [R=301,L]

  # -- Istanbul disi sehir sayfalari → genel hizmet bolgeleri --
  RewriteRule ^hizmet-bolgeleri/bursa(/.*)?$ /hizmet-bolgeleri/ [R=301,L]
  RewriteRule ^hizmet-bolgeleri/kocaeli(/.*)?$ /hizmet-bolgeleri/ [R=301,L]
  RewriteRule ^hizmet-bolgeleri/sakarya(/.*)?$ /hizmet-bolgeleri/ [R=301,L]
  RewriteRule ^hizmet-bolgeleri/tekirdag(/.*)?$ /hizmet-bolgeleri/ [R=301,L]
  RewriteRule ^hizmet-bolgeleri/yalova(/.*)?$ /hizmet-bolgeleri/ [R=301,L]

  # -- Eski /tabelacesitleri/ catch-all (birebir eslesmeyenler) --
  RewriteCond %{REQUEST_URI} ^/tabelacesitleri/ [NC]
  RewriteRule ^tabelacesitleri/(.*)$ /hizmetler/ [R=301,L]
</IfModule>

# ================================================
# URL REWRITING & HTTPS
# ================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force non-www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteCond %{HTTP_HOST} !^localhost [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # Trailing slash enforcement
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,4}$ [NC]
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [R=301,L]

  # Map trailing slash to .html (works even when directory with same name exists)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*)/$ $1.html [L]
</IfModule>

# ================================================
# COMPRESSION (Gzip/Deflate)
# ================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
  AddOutputFilterByType DEFLATE application/x-font-opentype
  AddOutputFilterByType DEFLATE application/x-font-otf
  AddOutputFilterByType DEFLATE application/x-font-truetype
  AddOutputFilterByType DEFLATE application/x-font-ttf
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE font/opentype
  AddOutputFilterByType DEFLATE font/otf
  AddOutputFilterByType DEFLATE font/ttf
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE image/x-icon
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml

  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  Header append Vary User-Agent
</IfModule>

# ================================================
# BROWSER CACHING
# ================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"

  # Images - 1 year
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts - 1 year
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # CSS/JS - 1 month
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"

  # HTML - 1 hour
  ExpiresByType text/html "access plus 1 hour"

  # XML (sitemap) - 1 day
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
</IfModule>

# ================================================
# SECURITY HEADERS
# ================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# ================================================
# FILE ACCESS RESTRICTIONS
# ================================================
<FilesMatch "^\.(?!well-known)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

<FilesMatch "(^#.*#|\.(bak|config|dist|fla|inc|ini|log|psd|sh|sql|sw[op])|~)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# ================================================
# ERROR PAGES
# ================================================
ErrorDocument 404 /404.html
