---
import Layout from '../../layouts/Layout.astro';
import Gallery from '../common/Gallery.astro';
import FAQ from '../seo/FAQ.astro';
import Breadcrumb from '../seo/Breadcrumb.astro';
import { loadImagesManifest } from '../../utils/imagesManifest';
import { buildImageAlt, getCategoryLabel } from '../../utils/imageSeo';

interface Props {
  lang?: 'tr' | 'en';
}

const { lang = 'tr' } = Astro.props;

const manifest = loadImagesManifest();
const totalImages = manifest.length;

const counts = new Map<string, number>();
manifest.forEach((img: any) => {
  counts.set(img.category, (counts.get(img.category) ?? 0) + 1);
});

const categories: Array<{ category: string; label: string; count: number }> = [];
const seen = new Set<string>();
manifest.forEach((img: any) => {
  if (!seen.has(img.category)) {
    categories.push({
      category: img.category,
      label: getCategoryLabel(img.category, lang),
      count: counts.get(img.category) ?? 0,
    });
    seen.add(img.category);
  }
});

const images = manifest.map((img: any) => ({
  paths: img.paths,
  category: img.category,
  alt: buildImageAlt({ category: img.category, lang }),
}));

const filterStyles = categories
  .map(
    (cat) =>
      `#gallery-page[data-active-category="${cat.category}"] .gallery-item:not([data-category="${cat.category}"]) { display: none; }`
  )
  .join('\n');

const content = {
  tr: {
    metaTitle: 'Tabela Galeri | İstanbul Tabela İmalatı Örnekleri & Proje Fotoğrafları - A2 Reklam',
    metaDescription: 'A2 Reklam tabela galeri: ışıklı tabela, kutu harf, cephe tabelası, totem tabela, araç giydirme ve paslanmaz harf proje fotoğrafları. İstanbul 39 ilçede 2.500+ tamamlanmış proje.',
    title: 'Tabela İmalatı Galeri',
    subtitle: 'İstanbul genelinde 2.500+ tamamlanmış tabela ve reklam projesinden seçilmiş örnekler.',
    filterLabel: 'Kategoriler',
    all: 'Tümü',
    showing: 'Gösterilen',
    of: ' / ',
    home: 'Anasayfa',
    gallery: 'Galeri',
  },
  en: {
    metaTitle: 'Signage Gallery | Istanbul Signage Manufacturing Projects & Photos - A2 Advertising',
    metaDescription: 'Browse A2 Advertising gallery: facade signage, channel letters, totems, vehicle wraps and custom signage projects. 2,500+ completed projects across 39 Istanbul districts.',
    title: 'Signage Manufacturing Gallery',
    subtitle: 'Selected examples from 2,500+ completed signage and branding projects across Istanbul.',
    filterLabel: 'Categories',
    all: 'All',
    showing: 'Showing',
    of: ' of ',
    home: 'Home',
    gallery: 'Gallery',
  },
};

const galleryFaqs = lang === 'tr' ? [
  {
    question: "Tabela projelerinin fotoğraflarını görebilir miyim?",
    answer: "Evet, bu sayfada A2 Reklam tarafından İstanbul genelinde gerçekleştirilen tabela projelerinin fotoğraflarını inceleyebilirsiniz. Cephe tabelası, ışıklı tabela, kutu harf, totem tabela, araç giydirme ve özel imalat kategorilerinde yüzlerce proje örneği mevcuttur."
  },
  {
    question: "Galerideki tabelalar hangi malzemelerden yapılmış?",
    answer: "Galerimizde paslanmaz çelik (304 ve 316 kalite), alüminyum profil, pleksiglas (akrilik), alüminyum kompozit panel (ACP), galvaniz sac ve PVC gibi farklı malzemelerden üretilmiş tabelalar yer almaktadır. Dış cephe projelerinde UV dayanımlı ve hava koşullarına dirençli malzemeler tercih edilirken, iç mekân uygulamalarında estetik ön planda tutulmaktadır."
  },
  {
    question: "Benzer bir tabela projesi için teklif alabilir miyim?",
    answer: "Elbette! Galerimizde beğendiğiniz herhangi bir projenin benzerini sizin için üretebiliriz. WhatsApp üzerinden veya iletişim formu aracılığıyla beğendiğiniz görseli paylaşarak ücretsiz teklif alabilirsiniz. Keşif ve ölçü hizmeti ücretsizdir. Teklifler genellikle 24 saat içinde hazırlanır."
  },
  {
    question: "Tabela montaj fotoğrafları gerçek projelerden mi?",
    answer: "Evet, galerideki tüm fotoğraflar A2 Reklam ekibinin İstanbul'un çeşitli ilçelerinde gerçekleştirdiği montaj ve imalat projelerine aittir. Her görsel, teslim edilen gerçek çalışmaları yansıtmaktadır. Stok fotoğraf veya yapay görsel kullanılmamaktadır."
  },
  {
    question: "Işıklı tabela ile ışıksız tabela arasındaki fark nedir?",
    answer: "Işıklı tabelalar LED modül veya neon flex aydınlatma içerir ve gece görünürlüğü sağlar; AVM, restoran ve cadde üzeri mağazalar için idealdir. Işıksız tabelalar ise gündüz görünürlüğüne dayalıdır, genellikle paslanmaz harf veya kompozit panel üzerine vinil kesim olarak üretilir. Işıklı tabelalar daha yüksek bütçe gerektirirken, ışıksız tabelalar daha ekonomiktir."
  },
  {
    question: "Tabela üretim ve montaj süreci ne kadar sürer?",
    answer: "Standart bir tabela projesi tasarım onayından itibaren 3–7 iş günü içinde tamamlanır. Süreç şu adımlardan oluşur: ücretsiz keşif ve ölçü, tasarım ve revizyon, üretim (CNC lazer kesim, boyama, LED montaj), yerinde montaj ve teslimat. Büyük çaplı projeler (AVM, plaza cephe giydirme) 2–4 hafta sürebilir."
  },
  {
    question: "Tabela projesi için belediye izni gerekli mi?",
    answer: "Evet, İstanbul'da dış cepheye tabela montajı için İBB veya ilçe belediyesinden reklam ruhsatı alınması gerekir. A2 Reklam olarak ruhsat başvuru sürecinde müşterilerimize rehberlik ediyoruz. Ruhsatsız tabela montajı idari para cezasına ve söküm işlemine neden olabilir."
  },
  {
    question: "Hangi sektörlere tabela hizmeti veriyorsunuz?",
    answer: "Restoran ve kafe zincirleri, perakende mağazalar, kurumsal ofisler, AVM'ler, hastane ve klinikler, otel ve konaklama tesisleri, akaryakıt istasyonları, lojistik şirketleri ve üretim tesisleri gibi çok çeşitli sektörlere hizmet veriyoruz. Her sektörün ihtiyacına özel tabela çözümleri sunmaktayız."
  },
] : [
  {
    question: "Can I see photos of your signage projects?",
    answer: "Yes, this page showcases signage projects completed by A2 Advertising across Istanbul. You can browse hundreds of examples in categories including facade signage, illuminated signs, channel letters, totem signs, vehicle wraps and custom fabrication."
  },
  {
    question: "What materials are used in the gallery projects?",
    answer: "Our gallery features signs made from stainless steel (304 and 316 grade), aluminum profiles, acrylic (plexiglass), aluminum composite panels (ACP), galvanized steel, and PVC. Outdoor projects use UV-resistant and weather-durable materials, while indoor applications prioritize aesthetics."
  },
  {
    question: "Can I get a quote for a similar signage project?",
    answer: "Absolutely! We can produce a similar version of any project you see in our gallery. Share the image you like via WhatsApp or our contact form to receive a free quote. Site survey and measurement services are complimentary. Quotes are typically prepared within 24 hours."
  },
  {
    question: "What is the difference between illuminated and non-illuminated signs?",
    answer: "Illuminated signs use LED modules or neon flex lighting for night visibility, ideal for malls, restaurants, and street-front shops. Non-illuminated signs rely on daytime visibility and are typically made from stainless steel letters or vinyl-cut composite panels. Illuminated signs require a higher budget but offer 24/7 brand visibility."
  },
  {
    question: "How long does sign production and installation take?",
    answer: "A standard signage project is completed within 3–7 business days after design approval. The process includes free site survey, design and revision, production (CNC laser cutting, painting, LED assembly), and on-site installation. Large-scale projects like mall facades may take 2–4 weeks."
  },
];

const t = content[lang];

const breadcrumbs = [
  { name: t.home, item: lang === 'en' ? '/en/' : '/' },
  { name: t.gallery, item: lang === 'en' ? '/en/gallery/' : '/galeri/' },
];
---

<Layout title={t.metaTitle} description={t.metaDescription} lang={lang} breadcrumbs={breadcrumbs}>
  <div class="container mx-auto px-4">
    <Breadcrumb items={breadcrumbs.map(b => ({ name: b.name, url: b.item }))} />
  </div>
  <section class="relative py-24 bg-secondary overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="text-center mb-12">
        <h1 class="font-heading font-bold text-4xl md:text-6xl mb-6 text-white uppercase tracking-tight">
          <span class="text-primary">{t.title}</span>
        </h1>
        <p
          class="text-gray-400 max-w-2xl mx-auto text-lg inline-block border-l-2 border-primary pl-4"
        >
          {t.subtitle}
        </p>
      </div>
    </div>
  </section>

  <section
    id="gallery-page"
    data-active-category="all"
    data-total={totalImages}
    class="py-16 bg-secondary border-t border-white/5"
  >
    <div class="container mx-auto px-4">
      <div class="flex flex-col gap-6">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <div class="flex flex-col gap-2">
            <span class="text-xs uppercase tracking-widest text-gray-500">{t.filterLabel}</span>
            <h2 class="text-white font-heading font-bold text-2xl">{t.title}</h2>
          </div>
          <div class="text-sm text-gray-400" aria-live="polite" aria-atomic="true">
            {t.showing} <span id="gallery-visible-count">{totalImages}</span>{t.of}<span id="gallery-total-count">{totalImages}</span>
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          <button
            type="button"
            class="filter-btn px-4 py-2 rounded-full border border-white/10 text-gray-300 text-sm font-medium hover:border-primary/60 hover:text-white transition-colors"
            data-filter="all"
            data-total={totalImages}
            aria-pressed="true"
            aria-controls="gallery-grid"
          >
            {t.all} ({totalImages})
          </button>
          {categories.map((cat) => (
            <button
              type="button"
              class="filter-btn px-4 py-2 rounded-full border border-white/10 text-gray-300 text-sm font-medium hover:border-primary/60 hover:text-white transition-colors"
              data-filter={cat.category}
              data-total={cat.count}
              aria-pressed="false"
              aria-controls="gallery-grid"
            >
              {cat.label} ({cat.count})
            </button>
          ))}
        </div>
      </div>

      <div class="mt-10">
        <Gallery images={images} lang={lang} initialLimit={totalImages} aspectRatio="square" />
      </div>
    </div>
  </section>

  {/* SEO Content Section */}
  {lang === 'tr' ? (
    <>
    <section class="py-16 bg-secondary border-t border-white/5">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="font-heading font-bold text-2xl md:text-3xl text-white mb-8 text-center uppercase tracking-tight">
            İstanbul'da <span class="text-primary">Tabela Uygulamaları</span> ve Projelerimiz
          </h2>
          <div class="prose prose-invert prose-sm md:prose-base max-w-none text-gray-400 leading-relaxed space-y-4">
            <p>
              <strong class="text-white">A2 Reklam</strong> olarak 2005 yılından bu yana İstanbul genelinde <strong class="text-white">2.500'den fazla tabela imalatı</strong> ve montaj projesi tamamladık. Bu galeride <strong class="text-white">cephe tabelası</strong>, <strong class="text-white">ışıklı tabela</strong>, <strong class="text-white">kutu harf</strong>, <strong class="text-white">totem tabela</strong>, <strong class="text-white">araç giydirme</strong>, <strong class="text-white">paslanmaz harf</strong> ve <strong class="text-white">özel imalat</strong> kategorilerindeki gerçek projelerimizi inceleyebilirsiniz. Her fotoğraf, müşterilerimize teslim ettiğimiz tamamlanmış çalışmalara aittir.
            </p>
            <p>
              Her proje, müşterinin marka kimliğine ve lokasyonuna uygun olarak özel tasarlanmaktadır. Üretim sürecimizde <strong class="text-white">CNC lazer kesim</strong>, <strong class="text-white">LED modül aydınlatma</strong>, <strong class="text-white">PVD kaplama</strong> ve <strong class="text-white">elektrostatik toz boya</strong> gibi modern endüstriyel teknolojiler kullanılmaktadır. Kağıthane'deki 400 m² üretim atölyemizden İstanbul'un 39 ilçesine keşif, imalat ve montaj hizmeti sunuyoruz.
            </p>
            <p>
              Galerimizde beğendiğiniz bir proje varsa benzerini sizin için de üretebiliriz. <a href="/iletisim/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Ücretsiz keşif ve teklif</a> için bizimle iletişime geçin veya <a href="https://wa.me/905316181672" class="text-primary hover:text-white transition-colors underline underline-offset-2" target="_blank" rel="noopener noreferrer">WhatsApp'tan</a> beğendiğiniz görseli gönderin.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Category Descriptions Section */}
    <section class="py-16 bg-secondary border-t border-white/5">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="font-heading font-bold text-2xl md:text-3xl text-white mb-10 text-center uppercase tracking-tight">
            Tabela <span class="text-primary">Kategorilerimiz</span>
          </h2>
          <div class="grid md:grid-cols-2 gap-8">
            <div class="border border-white/10 rounded-xl p-6 hover:border-primary/30 transition-colors">
              <h3 class="font-heading font-bold text-lg text-white mb-3">
                <a href="/hizmetler/cephe-tabela/" class="hover:text-primary transition-colors">Cephe Tabelası</a>
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                Bina dış cephelerine monte edilen, markanızı caddeye taşıyan tabela çözümleri. Alüminyum kompozit panel, paslanmaz çelik ve akrilik malzemelerle üretilir. Galerimizde restoran, mağaza ve kurumsal ofis cephe tabela örneklerini inceleyebilirsiniz.
              </p>
            </div>
            <div class="border border-white/10 rounded-xl p-6 hover:border-primary/30 transition-colors">
              <h3 class="font-heading font-bold text-lg text-white mb-3">
                <a href="/hizmetler/isikli-tabela/" class="hover:text-primary transition-colors">Işıklı Tabela</a>
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                LED modül veya neon flex aydınlatma ile gece-gündüz görünürlük sağlayan tabelalar. Kutu harf, light box ve kanal harf modelleri mevcuttur. AVM, cadde üzeri işletmeler ve akaryakıt istasyonları için ideal çözümlerdir. Enerji tasarruflu LED teknolojisi kullanılır.
              </p>
            </div>
            <div class="border border-white/10 rounded-xl p-6 hover:border-primary/30 transition-colors">
              <h3 class="font-heading font-bold text-lg text-white mb-3">
                <a href="/hizmetler/paslanmaz-harfler/" class="hover:text-primary transition-colors">Paslanmaz Harf & Kutu Harf</a>
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                304 veya 316 kalite paslanmaz çelikten CNC lazer kesim ile üretilen harfler. Fırçalı, parlak, mat siyah veya PVD gold kaplama seçenekleri mevcuttur. Plaza girişleri, otel lobiler ve kurumsal mekânlarda prestij sağlayan üst segment tabela çözümüdür.
              </p>
            </div>
            <div class="border border-white/10 rounded-xl p-6 hover:border-primary/30 transition-colors">
              <h3 class="font-heading font-bold text-lg text-white mb-3">
                <a href="/hizmetler/totem/" class="hover:text-primary transition-colors">Totem Tabela</a>
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                Yoldan geçen araç ve yayaların dikkatini çekmek için zemine monte edilen dikili tabela yapıları. Tek yüz veya çift yüz seçenekleriyle akaryakıt istasyonları, AVM'ler, iş merkezleri ve sanayi tesisleri için üretilir. 2 metreden 8 metreye kadar yükseklik seçenekleri mevcuttur.
              </p>
            </div>
            <div class="border border-white/10 rounded-xl p-6 hover:border-primary/30 transition-colors">
              <h3 class="font-heading font-bold text-lg text-white mb-3">
                <a href="/hizmetler/arac-giydirme/" class="hover:text-primary transition-colors">Araç Giydirme</a>
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                Cast veya polimerik folyo ile tam veya kısmi araç kaplama uygulamaları. Ticari filolar, servis araçları ve kurumsal araçlar için marka görünürlüğü sağlar. 3M, Avery Dennison ve Oracal gibi premium folyo markaları kullanılır. 5-7 yıl dayanıklılık sunar.
              </p>
            </div>
            <div class="border border-white/10 rounded-xl p-6 hover:border-primary/30 transition-colors">
              <h3 class="font-heading font-bold text-lg text-white mb-3">
                <a href="/hizmetler/ozel-imalatlar/" class="hover:text-primary transition-colors">Özel İmalatlar</a>
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                Standart kalıpların dışında, markanıza özel tasarlanan tabela ve dekoratif çözümler. Yönlendirme sistemleri, kapı isimlikler, ayaklı panolar, banko uygulamaları ve iç mekân branding projeleri bu kategoride yer alır. Her proje müşteriye özel ölçülendirilir.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Process & Trust Section */}
    <section class="py-16 bg-secondary border-t border-white/5">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="font-heading font-bold text-2xl md:text-3xl text-white mb-8 text-center uppercase tracking-tight">
            Tabela <span class="text-primary">Üretim Sürecimiz</span>
          </h2>
          <div class="prose prose-invert prose-sm md:prose-base max-w-none text-gray-400 leading-relaxed space-y-4">
            <p>
              Galerimizde gördüğünüz her projenin arkasında sistematik bir üretim süreci bulunmaktadır. <strong class="text-white">Ücretsiz keşif</strong> ile başlayan sürecimiz; cephe ölçümü, 3D tasarım ve müşteri onayı, malzeme tedariki, CNC kesim ve üretim, boya/kaplama, LED montajı, kalite kontrol ve yerinde montaj aşamalarından oluşur.
            </p>
            <p>
              <strong class="text-white">20 yılı aşkın sektör deneyimimiz</strong> ile İstanbul'un tüm ilçelerine hizmet veriyoruz. <a href="/hizmet-bolgeleri/besiktas-tabela/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Beşiktaş</a>, <a href="/hizmet-bolgeleri/sisli-tabela/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Şişli</a>, <a href="/hizmet-bolgeleri/kadikoy-tabela/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Kadıköy</a>, <a href="/hizmet-bolgeleri/uskudar-tabela/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Üsküdar</a>, <a href="/hizmet-bolgeleri/levent-tabela/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Levent</a> ve <a href="/hizmet-bolgeleri/maslak-tabela/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Maslak</a> başta olmak üzere 39 ilçede <strong class="text-white">aynı gün keşif</strong> imkânı sunmaktayız.
            </p>
            <p>
              Tüm projelerimizde <strong class="text-white">2 yıl işçilik garantisi</strong> ve <strong class="text-white">5 yıl LED garanti</strong> sunuyoruz. Google'da <strong class="text-white">5.0 puan</strong> ve <strong class="text-white">87 müşteri değerlendirmesi</strong> ile İstanbul'un en güvenilir tabela firmalarından biriyiz. <a href="/hakkimizda/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Hakkımızda</a> sayfasından daha fazla bilgi edinebilirsiniz.
            </p>
          </div>

          {/* Material Comparison Table */}
          <div class="mt-10 overflow-x-auto">
            <h3 class="font-heading font-bold text-xl text-white mb-4 uppercase tracking-tight">
              Tabela Malzeme Karşılaştırması
            </h3>
            <table class="w-full text-sm text-left text-gray-400 border border-white/10 rounded-lg overflow-hidden">
              <thead class="text-xs text-gray-300 uppercase bg-white/5">
                <tr>
                  <th class="px-4 py-3 border-b border-white/10">Malzeme</th>
                  <th class="px-4 py-3 border-b border-white/10">Dayanıklılık</th>
                  <th class="px-4 py-3 border-b border-white/10">Kullanım Alanı</th>
                  <th class="px-4 py-3 border-b border-white/10">Fiyat Aralığı</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-white/5">
                  <td class="px-4 py-3 text-white font-medium">Paslanmaz Çelik</td>
                  <td class="px-4 py-3">15-20 yıl</td>
                  <td class="px-4 py-3">Plaza, otel, kurumsal</td>
                  <td class="px-4 py-3">₺₺₺₺</td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="px-4 py-3 text-white font-medium">Alüminyum Kompozit</td>
                  <td class="px-4 py-3">10-15 yıl</td>
                  <td class="px-4 py-3">Cephe, mağaza, ofis</td>
                  <td class="px-4 py-3">₺₺₺</td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="px-4 py-3 text-white font-medium">Pleksiglas (Akrilik)</td>
                  <td class="px-4 py-3">8-12 yıl</td>
                  <td class="px-4 py-3">Işıklı tabela, kutu harf</td>
                  <td class="px-4 py-3">₺₺</td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="px-4 py-3 text-white font-medium">Galvaniz Sac</td>
                  <td class="px-4 py-3">10-15 yıl</td>
                  <td class="px-4 py-3">Totem, çatı tabelası</td>
                  <td class="px-4 py-3">₺₺₺</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 text-white font-medium">PVC / Forex</td>
                  <td class="px-4 py-3">3-5 yıl</td>
                  <td class="px-4 py-3">İç mekân, geçici tanıtım</td>
