---
import { REFERENCES } from '../../data/references';

interface Props {
  lang?: 'tr' | 'en';
}

const { lang = 'tr' } = Astro.props;
const references = REFERENCES ?? [];

// Don't render if no references configured
if (references.length === 0) {
  return null;
}

// Translations
const translations = {
  tr: {
    heading: 'Referanslarımız',
    subtitle: 'Birlikte çalıştığımız markalar ve kurumlar',
  },
  en: {
    heading: 'References',
    subtitle: 'Brands and businesses we\'ve delivered for',
  },
};

const t = translations[lang];
---

<section class="py-20 bg-secondary border-t border-white/5 relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="font-heading font-bold text-4xl md:text-5xl mb-4 text-white uppercase tracking-tight">
        {t.heading}
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-lg">
        {t.subtitle}
      </p>
    </div>

    <!-- References Grid with Glass Cards -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 place-items-center">
      {references.map((reference) => (
        <a
          href={reference.url}
          target="_blank"
          rel="noopener noreferrer"
          data-track="outbound"
          data-outbound-type="reference"
          data-outbound-target="references_section"
          data-outbound-name={reference.name}
          data-lang={lang}
          class="glass-card group relative w-full overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-secondary"
          aria-label={`${reference.name} - ${lang === 'en' ? 'Visit site' : 'Siteyi ziyaret et'}`}
        >
          <div class="aspect-[3/2] flex items-center justify-center p-5 md:p-6">
            {reference.logo ? (
              <img
                src={reference.logo}
                alt={`${reference.name} logo`}
                width="180"
                height="72"
                decoding="async"
                class="max-w-full max-h-full object-contain opacity-100 saturate-[1.35] contrast-[1.08] group-hover:scale-105 transition-all duration-300"
                loading="lazy"
              />
            ) : (
              <div class="text-center">
                <div class="text-gray-300 font-heading font-bold text-xs md:text-sm uppercase tracking-wide group-hover:text-white transition-colors">
                  {reference.name}
                </div>
              </div>
            )}
          </div>
          <span class="absolute top-2 right-2 text-[10px] uppercase tracking-wide text-white/55 group-hover:text-primary transition-colors">
            {lang === 'en' ? 'Visit site' : 'Siteyi ziyaret et'}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
