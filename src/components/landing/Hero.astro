---
import { PHONE_NUMBER, PHONE_TEL, WHATSAPP_LINK, GOOGLE_RATING, GOOGLE_REVIEW_COUNT } from '../../consts';

interface Props {
  lang?: string;
}
const { lang = 'tr' } = Astro.props;

const content = {
  tr: {
    badge: "⭐ 5.0 / 90 Yorum · 2005'ten Beri Tabelacı",
    titleBefore: 'İstanbul',
    titleAfter: 'İmalatçısı',
    subtitle: "20+ yıllık atölyemizde kendi üretimimiz. AVM, plaza, hastane, otel ve dükkan tabelası. Aracısız üretici fiyatı, 2 yıl garanti, aynı gün keşif.",
    call: 'Hemen Ara',
    whatsapp: 'WhatsApp',
    quote: 'Ücretsiz Teklif Al',
    quoteLink: '/iletisim/',
    words: ['Tabelacısı', 'Tabela İmalatı', 'Kurumsal Tabela', 'LED Kutu Harf', 'Cephe Tabelası', 'AVM Tabelası'],
  },
  en: {
    badge: '⭐ 5.0 / 90 Reviews · Since 2005',
    titleBefore: 'Istanbul',
    titleAfter: 'Manufacturer',
    subtitle: 'Own workshop, 20+ years. Mall, plaza, hospital, hotel & shop signs. Direct factory pricing, 2-year warranty, same-day visit.',
    call: 'Call Now',
    whatsapp: 'WhatsApp',
    quote: 'Get Free Quote',
    quoteLink: '/en/get-quote/',
    words: ['Sign Maker', 'Signage Manufacturer', 'Corporate Signs', 'LED Channel Letters', 'Facade Signs', 'Mall Signage'],
  },
};

const t = lang === 'en' ? content.en : content.tr;
const wordsJson = JSON.stringify(t.words);

// Video: use cephe-tabela-01 as default hero video
const videoSrc = '/assets/videos/cephe-tabela-01.mp4';
const posterSrc = '/assets/videos/posters/cephe-tabela-01.webp';
---

<section
  class="hero-split relative min-h-[75vh] flex items-stretch overflow-hidden bg-[#0B0F14]"
  aria-label={lang === 'en' ? 'Hero section' : 'Ana banner'}
>
  <!-- LEFT SIDE: Text Content -->
  <div class="hero-left relative z-10 flex flex-col justify-center w-full lg:w-[55%] px-6 sm:px-10 lg:px-16 xl:px-24 py-16 lg:py-20">
    <!-- Badge -->
    <div class="hero-anim hero-anim-badge mb-5">
      <span class="inline-block px-4 py-1.5 border border-primary/40 rounded-full bg-primary/10 text-primary text-sm font-semibold tracking-wider uppercase">
        {t.badge}
      </span>
    </div>

    <!-- Title with typewriter -->
    <h1 class="hero-anim hero-anim-title font-heading font-bold text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-tight text-white mb-6">
      {t.titleBefore}{' '}
      <span class="hero-typewriter-wrapper inline-flex items-baseline">
        <span id="hero-typewriter" class="text-primary">{t.words[0]}</span>
        <span class="hero-cursor" aria-hidden="true">|</span>
      </span>
      <br />
      {t.titleAfter}
    </h1>

    <!-- Subtitle -->
    <p class="hero-anim hero-anim-subtitle text-lg sm:text-xl text-gray-400 max-w-lg mb-10 leading-relaxed">
      {t.subtitle}
    </p>

    <!-- BIG PHONE CTA - Kullanıcının direkt arayabilmesi için -->
    <div class="hero-anim hero-anim-cta mb-6">
      <a
        href={`tel:${PHONE_TEL}`}
        data-track="call"
        data-lang={lang}
        class="group inline-flex items-center gap-4 bg-primary text-secondary px-6 py-5 rounded-2xl shadow-2xl shadow-primary/40 hover:bg-white hover:shadow-primary/60 transition-all transform hover:-translate-y-1 border-2 border-primary/60"
        aria-label={`Hemen ara: ${PHONE_NUMBER}`}
      >
        <span class="relative flex h-14 w-14 items-center justify-center rounded-full bg-secondary/20">
          <svg class="w-7 h-7 relative z-10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57-.35-.11-.74-.03-1.02.24l-2.2 2.2c-2.83-1.44-5.15-3.75-6.59-6.58l2.2-2.21c.27-.27.35-.67.24-1.02A11.36 11.36 0 013.5 4c0-.55-.45-1-1-1H1c-.55 0-1 .45-1 1 0 10.51 8.49 19 19 19 .55 0 1-.45 1-1v-1.5c0-.55-.45-1-1-1z"/>
          </svg>
          <span class="absolute inset-0 rounded-full bg-secondary/30 animate-ping" style="animation-duration:1.8s;" aria-hidden="true"></span>
        </span>
        <div class="flex flex-col items-start leading-tight">
          <span class="text-xs uppercase tracking-widest opacity-80 font-bold">{t.call} ·  ücretsiz keşif</span>
          <span class="text-2xl md:text-3xl font-black">{PHONE_NUMBER}</span>
        </div>
      </a>
    </div>

    <!-- Ek CTA'lar -->
    <div class="hero-anim hero-anim-cta flex flex-col sm:flex-row gap-3">
      <a
        href={WHATSAPP_LINK}
        target="_blank"
        rel="noopener noreferrer"
        data-track="whatsapp"
        data-lang={lang}
        class="hero-cta-whatsapp px-6 py-3 text-sm font-bold uppercase tracking-wide"
      >
        {t.whatsapp}
      </a>
      <a
        href={t.quoteLink}
        data-track="quote"
        data-lang={lang}
        class="hero-cta-secondary px-6 py-3 text-sm font-bold uppercase tracking-wide"
      >
        {t.quote}
      </a>
    </div>
  </div>

  <!-- RIGHT SIDE: Video with diagonal clip (desktop only) -->
  <div class="hero-right hidden lg:block absolute lg:relative w-full lg:w-[45%] h-full min-h-[75vh]">
    <!-- Diagonal gold accent line -->
    <div class="hero-diagonal-accent" aria-hidden="true"></div>

    <div class="hero-video-container">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={posterSrc}
        fetchpriority="high"
        class="hero-video"
        aria-label={lang === 'en' ? 'Signage production showcase' : 'Tabela üretim tanıtımı'}
      >
        <source src={videoSrc} type="video/mp4" />
      </video>
      <!-- Subtle dark overlay for depth -->
      <div class="absolute inset-0 bg-black/10 z-10"></div>
    </div>
  </div>

  <!-- MOBILE: Video background (shown below lg) -->
  <div class="hero-mobile-video lg:hidden absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster={posterSrc}
      class="w-full h-full object-cover"
      aria-hidden="true"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0B0F14]/70 via-[#0B0F14]/85 to-[#0B0F14]/95 z-10"></div>
  </div>
</section>

<script define:vars={{ wordsJson }}>
(function () {
  const el = document.getElementById('hero-typewriter');
  if (!el) return;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReducedMotion) return;

  const words = JSON.parse(wordsJson);
  let wordIndex = 0;
  let charIndex = words[0].length;
  let isDeleting = false;

  const TYPE_SPEED = 80;
  const DELETE_SPEED = 50;
  const PAUSE_AFTER_TYPE = 3000;
  const PAUSE_AFTER_DELETE = 400;

  function tick() {
    const currentWord = words[wordIndex];

    if (!isDeleting) {
      el.textContent = currentWord.slice(0, charIndex);
      charIndex++;

      if (charIndex > currentWord.length) {
        isDeleting = true;
        setTimeout(tick, PAUSE_AFTER_TYPE);
        return;
      }
      setTimeout(tick, TYPE_SPEED);
    } else {
      charIndex--;
      el.textContent = currentWord.slice(0, charIndex);

      if (charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        setTimeout(tick, PAUSE_AFTER_DELETE);
        return;
      }
      setTimeout(tick, DELETE_SPEED);
    }
  }

  // Start after initial display pause
  setTimeout(() => {
    isDeleting = true;
    tick();
  }, PAUSE_AFTER_TYPE);
})();
</script>

<style>
  /* ============================================
     HERO SPLIT - Diagonal Layout
     ============================================ */

  /* Typewriter cursor blink */
  .hero-cursor {
    color: #C9A227;
    font-weight: 300;
    animation: heroBlink 1s step-end infinite;
    margin-left: 2px;
  }

  @keyframes heroBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Right side: diagonal clip-path */
  .hero-video-container {
    position: absolute;
    inset: 0;
    clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%);
    overflow: hidden;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Diagonal gold accent line */
  .hero-diagonal-accent {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 20;
    pointer-events: none;
  }

  .hero-diagonal-accent::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 100%;
    clip-path: polygon(15% 0, calc(15% + 3px) 0, 3px 100%, 0% 100%);
    background: linear-gradient(
      to bottom,
      rgba(201, 162, 39, 0.5) 0%,
      rgba(201, 162, 39, 1) 50%,
      rgba(201, 162, 39, 0.5) 100%
    );
  }

  .hero-diagonal-accent::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 100%;
    clip-path: polygon(15% 0, calc(15% + 12px) 0, 12px 100%, 0% 100%);
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(201, 162, 39, 0.15) 50%,
      transparent 100%
    );
    filter: blur(4px);
  }

  /* Entry animations */
  .hero-anim {
    opacity: 0;
    transform: translateX(-30px);
    animation: heroSlideInLeft 0.7s ease-out forwards;
    will-change: transform, opacity;
  }

  .hero-anim-badge { animation-delay: 0.1s; }
  .hero-anim-title { animation-delay: 0.25s; }
  .hero-anim-subtitle { animation-delay: 0.4s; }
  .hero-anim-cta { animation-delay: 0.55s; }

  .hero-right {
    opacity: 0;
    transform: translateX(30px);
    animation: heroSlideInRight 0.7s ease-out 0.2s forwards;
    will-change: transform, opacity;
  }

  @keyframes heroSlideInLeft {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes heroSlideInRight {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* CTA Buttons — always on dark bg, theme-agnostic */
  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #C9A227;
    color: #0B0F14 !important;
    border-radius: 0.5rem;
    box-shadow:
      0 4px 12px rgba(201, 162, 39, 0.4),
      0 2px 4px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .hero-cta-primary:hover {
    background-color: #E0B945;
    transform: translateY(-2px);
    box-shadow:
      0 6px 16px rgba(201, 162, 39, 0.5),
      0 3px 6px rgba(0, 0, 0, 0.3);
  }

  .hero-cta-primary:focus-visible {
    outline: 2px solid #C9A227;
    outline-offset: 2px;
  }

  .hero-cta-whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #16a34a;
    color: #FFFFFF !important;
    border-radius: 0.5rem;
    box-shadow:
      0 4px 12px rgba(22, 163, 74, 0.38),
      0 2px 4px rgba(0, 0, 0, 0.28);
    transition: all 0.2s ease;
  }

  .hero-cta-whatsapp:hover {
    background-color: #22c55e;
    transform: translateY(-2px);
    box-shadow:
      0 6px 16px rgba(22, 163, 74, 0.42),
      0 3px 6px rgba(0, 0, 0, 0.3);
  }

  .hero-cta-whatsapp:focus-visible {
    outline: 2px solid #22c55e;
    outline-offset: 2px;
  }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    color: #FFFFFF !important;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .hero-cta-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: #FFFFFF;
    transform: translateY(-2px);
  }

  .hero-cta-secondary:focus-visible {
    outline: 2px solid #FFFFFF;
    outline-offset: 2px;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-anim,
    .hero-right {
      opacity: 1;
      transform: none;
      animation: none !important;
    }

    .hero-cursor {
      animation: none;
      opacity: 1;
    }

    .hero-cta-primary:hover,
    .hero-cta-whatsapp:hover,
    .hero-cta-secondary:hover {
      transform: none;
    }
  }
</style>
