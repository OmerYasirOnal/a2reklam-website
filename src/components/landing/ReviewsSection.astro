---
import { REVIEWS } from '../../data/reviews';
import { GOOGLE_REVIEWS_URL, GOOGLE_RATING, GOOGLE_REVIEW_COUNT } from '../../consts';

interface Props {
  lang?: 'tr' | 'en';
}

const { lang = 'tr' } = Astro.props;
const currentLang = lang as 'tr' | 'en';

// Get reviews for this language (show top 6, highlight first)
const displayedReviews = REVIEWS.slice(0, 6);

// Translations
const translations = {
  tr: {
    heading: 'Memnun Müşterilerimiz',
    subtitle: 'Google Haritalar yorumlarımızı inceleyin.',
    viewAll: 'Google\'da Tüm Yorumları Gör',
    ratingLabel: '/5',
    reviewCountLabel: 'yorum',
    onGoogle: 'Google\'da',
  },
  en: {
    heading: 'Customer Reviews',
    subtitle: 'See our Google Maps reviews.',
    viewAll: 'View All on Google',
    ratingLabel: '/5',
    reviewCountLabel: 'reviews',
    onGoogle: 'on Google',
  },
};

const t = translations[currentLang];
---

<section class="py-14 md:py-16 bg-secondary border-t border-white/5 relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="font-heading font-bold text-3xl md:text-4xl mb-3 text-white uppercase tracking-tight">
        {t.heading}
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-base md:text-lg">
        {t.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 items-start">
      <!-- Trust Block (Left side on desktop, right on RTL) -->
      <div class="lg:col-span-1 order-2 lg:order-1">
        <div class="glass-card-padded text-center sticky top-24">
          <!-- Profile Photo -->
          <img
            src="/brand/a2reklam-google-profile.jpg"
            alt="A2 Reklam Google Profili"
            class="w-20 h-20 rounded-full border-2 border-primary object-cover mx-auto mb-2"
            loading="lazy"
          />
          <div class="text-white font-semibold text-sm mb-4">A2 Reklam</div>

          {GOOGLE_RATING && GOOGLE_REVIEW_COUNT ? (
            <>
              <div class="flex items-center justify-center gap-1 mb-3">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    class:list={[
                      'w-6 h-6',
                      i < Math.floor(GOOGLE_RATING) ? 'text-primary fill-primary' : 'text-gray-600',
                    ]}
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                  </svg>
                ))}
              </div>
              <div class="text-3xl font-black text-white mb-1">
                {GOOGLE_RATING}{t.ratingLabel}
              </div>
              <div class="text-sm text-gray-400 mb-6">
                {GOOGLE_REVIEW_COUNT} {t.reviewCountLabel}
              </div>
            </>
          ) : (
            <div class="mb-6">
              <p class="text-sm text-gray-400 mb-4">
                {currentLang === 'en' ? 'See our reviews' : 'Yorumlarımızı görüntüleyin'}
              </p>
            </div>
          )}

          <a
            href={GOOGLE_REVIEWS_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-track="outbound"
            data-outbound-type="google_reviews"
            data-outbound-target="maps_profile"
            data-lang={lang}
            class="btn btn-primary w-full text-sm font-bold uppercase tracking-wide"
          >
            {t.viewAll}
          </a>
        </div>
      </div>

      <!-- Review Cards (Right side on desktop, left on RTL) -->
      <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-2 gap-6 order-1 lg:order-2">
        {displayedReviews.map((review) => {
          const reviewText = review.text[currentLang] || review.text.tr;
          // Deep review links can resolve to empty Maps pages for some users.
          // Always route cards to the stable business profile URL.
          const reviewUrl = GOOGLE_REVIEWS_URL;
          return (
            <a
              href={reviewUrl}
              target="_blank"
              rel="noopener noreferrer"
              data-track="outbound"
              data-outbound-type="google_reviews"
              data-outbound-target="review_card"
              data-outbound-name={review.author}
              data-lang={lang}
              class="glass-card group p-6 block hover:border-primary/30 transition-all duration-300"
              aria-label={`${review.author} - ${currentLang === 'en' ? 'Open review' : 'Yorumu aç'}`}
            >
              {review.rating && (
                <div class="flex items-center gap-1 mb-4" aria-label={`${review.rating} out of 5 stars`}>
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg
                      class="w-4 h-4"
                      class:list={[
                        i < review.rating ? 'text-primary fill-primary' : 'text-gray-600',
                      ]}
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                    </svg>
                  ))}
                </div>
              )}
              
              <p class="text-gray-300 text-sm leading-relaxed mb-4 line-clamp-4 group-hover:line-clamp-none transition-all duration-300">
                "{reviewText}"
              </p>
              
              <div class="flex items-center justify-between pt-4 border-t border-white/5">
                <div>
                  <div class="text-white font-semibold text-sm">{review.author}</div>
                  {review.date && (
                    <div class="text-gray-500 text-xs mt-1">
                      {review.date}
                    </div>
                  )}
                </div>
                <svg class="w-5 h-5 text-primary/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>
