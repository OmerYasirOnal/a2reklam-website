---
import { MAPS_EMBED_URL } from '../../consts';

interface Props {
  src?: string;
  title?: string;
  className?: string;
}

const {
  src = MAPS_EMBED_URL,
  title = 'Google Maps',
  className = '',
} = Astro.props;
---

<div class:list={['h-64 md:h-80 w-full rounded-2xl overflow-hidden border border-primary/20 shadow-xl shadow-primary/5 map-embed', className]}>
  <style>
    .map-embed {
      position: relative;
    }
    .map-embed iframe {
      filter: saturate(1.1) contrast(1.05);
      transition: filter 0.3s ease;
    }
    .map-embed:hover iframe {
      filter: saturate(1.2) contrast(1.1);
    }
  </style>
  <iframe
    src={src}
    title={title}
    width="100%"
    height="100%"
    style="border:0;"
    aria-label="Google Maps - A2 Reklam konumu"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</div>
