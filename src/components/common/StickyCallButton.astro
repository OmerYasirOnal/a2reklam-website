---
/**
 * StickyCallButton — DESKTOP floating phone CTA (sağ altta sabit)
 * Mobil: MobileCTA kullanılıyor (ayrı bileşen, alt bar)
 */
import { PHONE_NUMBER, PHONE_TEL } from '../../consts';
---

<div class="hidden md:flex fixed bottom-6 right-6 z-40 flex-col gap-3 pointer-events-none">
  <a
    href={`tel:${PHONE_TEL}`}
    data-track="call"
    data-lang="tr"
    class="pointer-events-auto group flex items-center gap-3 bg-primary text-secondary font-black px-5 py-4 rounded-2xl shadow-2xl shadow-primary/50 hover:bg-white transition-all transform hover:scale-105 border-2 border-white/20"
    aria-label={`${PHONE_NUMBER} numarasını ara`}
  >
    <span class="relative flex h-10 w-10 items-center justify-center rounded-full bg-secondary/20">
      <svg class="w-5 h-5 relative z-10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57-.35-.11-.74-.03-1.02.24l-2.2 2.2c-2.83-1.44-5.15-3.75-6.59-6.58l2.2-2.21c.27-.27.35-.67.24-1.02A11.36 11.36 0 013.5 4c0-.55-.45-1-1-1H1c-.55 0-1 .45-1 1 0 10.51 8.49 19 19 19 .55 0 1-.45 1-1v-1.5c0-.55-.45-1-1-1z"/>
      </svg>
      <span class="absolute inset-0 rounded-full bg-secondary/20 animate-ping" style="animation-duration:1.8s;"></span>
    </span>
    <div class="flex flex-col leading-tight">
      <span class="text-xs uppercase tracking-wider opacity-80 font-bold">Hemen Ara</span>
      <span class="text-lg font-black">{PHONE_NUMBER}</span>
    </div>
  </a>
</div>
