---
/**
 * StickyCallButton — DESKTOP floating phone CTA (sağ altta sabit)
 * Call + WhatsApp combined, BackToTop'a çakışmayacak şekilde konumlandı.
 * Mobil: MobileCTA (alt bar) kullanılıyor.
 */
import { PHONE_NUMBER, PHONE_TEL } from '../../consts';
import { buildWhatsAppLink, buildWhatsAppMessage } from '../../utils/whatsapp';

const waMessage = buildWhatsAppMessage({ lang: 'tr' });
const waLink = buildWhatsAppLink(waMessage);
---

<div class="sticky-call-desktop hidden md:flex fixed bottom-6 right-6 z-40 items-end gap-3">
  <!-- WhatsApp (küçük, yan) -->
  <a
    href={waLink}
    target="_blank"
    rel="noopener"
    data-track="whatsapp"
    data-lang="tr"
    class="flex items-center justify-center w-14 h-14 bg-[#25D366] text-white rounded-full shadow-xl hover:bg-[#1ebe5b] transition-all transform hover:scale-105 border-2 border-white/20"
    aria-label="WhatsApp'tan mesaj gönder"
    title="WhatsApp"
  >
    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.334.101 11.893c0 2.096.549 4.14 1.595 5.945L0 24l6.335-1.652a11.882 11.882 0 005.71 1.447h.005c6.581 0 11.939-5.334 11.941-11.893a11.821 11.821 0 00-3.47-8.45M12.05 21.785h-.004a9.869 9.869 0 01-5.031-1.378l-.361-.214-3.741.975 1.005-3.648-.235-.374a9.86 9.86 0 01-1.511-5.26c.002-5.45 4.456-9.884 9.942-9.884 2.654 0 5.145 1.031 7.021 2.9a9.825 9.825 0 012.909 6.99c-.003 5.45-4.457 9.893-9.935 9.893"/>
    </svg>
  </a>

  <!-- Hemen Ara + Numara (büyük, vurgu) -->
  <a
    href={`tel:${PHONE_TEL}`}
    data-track="call"
    data-lang="tr"
    class="group flex items-center gap-3 bg-primary text-secondary font-black px-5 py-4 rounded-2xl shadow-2xl shadow-primary/50 hover:bg-white transition-all transform hover:scale-105 border-2 border-white/20"
    aria-label={`${PHONE_NUMBER} numarasını ara`}
  >
    <span class="relative flex h-10 w-10 items-center justify-center rounded-full bg-secondary/20">
      <svg class="w-5 h-5 relative z-10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57-.35-.11-.74-.03-1.02.24l-2.2 2.2c-2.83-1.44-5.15-3.75-6.59-6.58l2.2-2.21c.27-.27.35-.67.24-1.02A11.36 11.36 0 013.5 4c0-.55-.45-1-1-1H1c-.55 0-1 .45-1 1 0 10.51 8.49 19 19 19 .55 0 1-.45 1-1v-1.5c0-.55-.45-1-1-1z"/>
      </svg>
      <span class="absolute inset-0 rounded-full bg-secondary/20 animate-ping" style="animation-duration:1.8s;"></span>
    </span>
    <div class="flex flex-col leading-tight">
      <span class="text-xs uppercase tracking-wider opacity-80 font-bold">Hemen Ara</span>
      <span class="text-lg font-black">{PHONE_NUMBER}</span>
    </div>
  </a>
</div>
