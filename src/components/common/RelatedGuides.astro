---
/**
 * RelatedGuides — yüksek-otoriteli ilçe/sektör sayfalarından blog + tabela-rehberi
 * cluster'ına iç link (PageRank dağıtımı + topical authority). Curated evergreen rehberler;
 * her ilçe/sektör sayfasında görünür → 108 içerik sayfası inbound link alır.
 */
const guides = [
  { title: 'Tabela Fiyatlarını Etkileyen Faktörler', href: '/tabela-rehberi/tabela-fiyatlarini-etkileyen-faktorler/' },
  { title: 'Tabela İmalat Süreci Adım Adım', href: '/tabela-rehberi/tabela-imalat-sureci/' },
  { title: 'Tabela İzin ve Ruhsat İşlemleri', href: '/tabela-rehberi/tabela-izin-ruhsat-islemleri/' },
  { title: 'Işıklı Tabela Çeşitleri Rehberi', href: '/tabela-rehberi/isikli-tabela-cesitleri/' },
];
---

<section class="mb-10">
  <h2 class="font-heading text-2xl font-semibold text-white mb-6">İlgili Rehberler</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {guides.map((g) => (
      <a href={g.href} class="glass-card p-4 flex items-center justify-between gap-3 group">
        <span class="text-sm font-medium text-white group-hover:text-primary transition-colors">{g.title}</span>
        <svg class="w-4 h-4 text-gray-500 group-hover:text-primary shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </a>
    ))}
  </div>
  <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
    <a href="/tabela-rehberi/" class="text-primary hover:text-primary-hover font-medium">Tüm rehberler →</a>
    <a href="/blog/" class="text-primary hover:text-primary-hover font-medium">Blog yazıları →</a>
  </div>
</section>
