---
/**
 * CallBand — İçerik arasına yerleştirilen telefon CTA bandı
 * Kullanım: <CallBand context="Paslanmaz Harf" />
 */
import { PHONE_NUMBER, PHONE_TEL } from '../../consts';

interface Props {
  context?: string; // "Paslanmaz Harf", "Kağıthane", vb.
  variant?: 'default' | 'compact';
}

const { context, variant = 'default' } = Astro.props;

const ctaText = context
  ? `${context} projeniz için hemen arayın`
  : 'Projeniz için hemen arayın';
---

{variant === 'default' ? (
  <div class="call-band my-10 relative overflow-hidden rounded-2xl border border-primary/20 bg-gradient-to-r from-primary/10 via-primary/5 to-transparent p-6 md:p-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-center md:text-left">
        <p class="text-white font-heading font-bold text-lg md:text-xl mb-1">
          {ctaText}
        </p>
        <p class="text-gray-400 text-sm">
          Ücretsiz keşif randevusu alın — aynı gün dönüş garantisi
        </p>
      </div>
      <div class="flex flex-col sm:flex-row items-center gap-3">
        <a
          href={`tel:${PHONE_TEL}`}
          data-track="call"
          data-lang="tr"
          class="call-band-btn group flex items-center gap-3 bg-primary text-secondary font-black px-6 py-3.5 rounded-xl hover:bg-white transition-all transform hover:-translate-y-0.5 shadow-lg shadow-primary/30 text-sm uppercase tracking-widest whitespace-nowrap"
        >
          <span class="call-ring relative flex h-8 w-8 items-center justify-center rounded-full bg-secondary/20">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="absolute inset-0 rounded-full bg-secondary/10 animate-ping" style="animation-duration: 2s;"></span>
          </span>
          {PHONE_NUMBER}
        </a>
        <a
          href={`https://wa.me/905316181672?text=${encodeURIComponent(ctaText)}`}
          target="_blank"
          rel="noopener noreferrer"
          data-track="whatsapp"
          data-lang="tr"
          class="flex items-center gap-2 bg-green-600 text-white font-bold px-5 py-3.5 rounded-xl hover:bg-green-500 transition-all text-sm whitespace-nowrap"
        >
          <img src="/assets/icons/social/whatsapp-white.svg" alt="" width="18" height="18" class="w-[18px] h-[18px]" loading="lazy" decoding="async" aria-hidden="true" />
          WhatsApp
        </a>
      </div>
    </div>
    <!-- Decorative glow -->
    <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  </div>
) : (
  <!-- Compact variant — tek satır -->
  <a
    href={`tel:${PHONE_TEL}`}
    data-track="call"
    data-lang="tr"
    class="call-band-compact my-6 flex items-center justify-center gap-3 rounded-xl border border-primary/20 bg-primary/5 px-4 py-3 text-primary font-bold hover:bg-primary hover:text-secondary transition-all group"
  >
    <svg class="w-5 h-5 group-hover:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    <span>{PHONE_NUMBER}</span>
    <span class="text-gray-400 text-sm font-normal group-hover:text-secondary/70">— {ctaText}</span>
  </a>
)}
