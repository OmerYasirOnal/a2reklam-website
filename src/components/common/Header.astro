---
import { PHONE_TEL } from '../../consts';
import { districts } from '../../data/districts';
import { sectors } from '../../data/sectors';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang?: string;
}

const { lang = 'tr' } = Astro.props;

const items = [
  { label: 'Anasayfa', href: '/' },
  { label: 'Hizmetler', href: '/hizmetler/' },
  { label: 'Galeri', href: '/galeri/' },
  { label: 'Tabela Rehberleri', href: '/tabela-rehberi/' },
  { label: 'Hakkımızda', href: '/hakkimizda/' },
  { label: 'S.S.S', href: '/sss/' },
  { label: 'İletişim', href: '/iletisim/' },
];

const topDistricts = districts.filter(d => d.priority === 1).slice(0, 10);
const topSectors = sectors.slice(0, 8);

const homeLink = '/';
const callLabel = 'Hemen Ara';
const menuLabel = 'Menü';
const closeLabel = 'Kapat';
---

<header id="main-header" class="sticky top-0 z-50 glass-bar header-modern header-visible">
  <div class="container mx-auto px-4 h-20 flex items-center justify-between gap-4">
    <!-- Logo - Never shrinks, always visible -->
    <a href={homeLink} class="flex-shrink-0 flex items-center focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-secondary rounded-lg" aria-label="A2 Reklam">
      <img
        src="/brand/a2reklam-logo.png"
        alt="A2 Reklam Logo"
        width="140"
        height="50"
        class="h-10 sm:h-12 w-auto"
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <!-- Desktop Navigation - Hidden below lg -->
    <nav class="hidden lg:flex items-center gap-4 xl:gap-6">
      <a href="/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap">Anasayfa</a>
      <a href="/hizmetler/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap">Hizmetler</a>

      <!-- Hizmet Bölgeleri Dropdown -->
      <div class="relative group">
        <a href="/istanbul-tabelaci/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap flex items-center gap-1">
          Bölgeler
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div class="bg-secondary/95 backdrop-blur-lg border border-white/10 rounded-xl shadow-2xl p-4 w-56">
            {topDistricts.map(d => (
              <a href={`/${d.slug}/`} class="block py-1.5 px-3 text-sm text-gray-300 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">
                {d.name} Tabelacı
              </a>
            ))}
            <div class="border-t border-white/10 mt-2 pt-2">
              <a href="/istanbul-tabelaci/" class="block py-1.5 px-3 text-sm text-primary font-bold hover:text-white transition-colors">
                Tüm İlçeler &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Sektörler Dropdown -->
      <div class="relative group">
        <a href="/sektorel/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap flex items-center gap-1">
          Sektörler
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div class="bg-secondary/95 backdrop-blur-lg border border-white/10 rounded-xl shadow-2xl p-4 w-56">
            {topSectors.map(s => (
              <a href={`/sektorel/${s.slug}/`} class="block py-1.5 px-3 text-sm text-gray-300 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">
                {s.icon} {s.name}
              </a>
            ))}
            <div class="border-t border-white/10 mt-2 pt-2">
              <a href="/sektorel/" class="block py-1.5 px-3 text-sm text-primary font-bold hover:text-white transition-colors">
                Tüm Sektörler &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>

      <a href="/galeri/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap">Galeri</a>
      <a href="/tabela-rehberi/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap">Rehber</a>
      <a href="/hakkimizda/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap">Hakkımızda</a>
      <a href="/sss/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap">S.S.S</a>
      <a href="/iletisim/" class="text-sm font-medium text-gray-300 hover:text-primary transition-colors uppercase tracking-wide whitespace-nowrap">İletişim</a>
    </nav>

    <!-- Right Controls - Flexible layout -->
    <div class="flex items-center gap-2 md:gap-3">
      <!-- Theme Toggle (desktop) -->
      <div class="hidden lg:flex items-center gap-2">
        <ThemeToggle lang={lang} />
      </div>

      <!-- Call Button (desktop only) -->
      <a href={`tel:${PHONE_TEL}`} data-track="call" data-lang={lang} class="hidden lg:inline-flex btn btn-primary px-4 xl:px-6 py-2.5 text-sm font-bold whitespace-nowrap flex-shrink-0">
        {callLabel}
      </a>

      <!-- Mobile Menu Toggle - Always visible below lg -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden p-2 text-white hover:text-primary transition-colors flex-shrink-0"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        aria-haspopup="dialog"
        aria-label={menuLabel}
      >
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] transform transition-transform duration-300 md:hidden pointer-events-none translate-x-full"
  aria-hidden="true"
  inert
>
  <!-- Backdrop -->
  <div
    id="mobile-menu-backdrop"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"
    aria-hidden="true"
    tabindex="-1"
  ></div>

  <!-- Drawer Panel -->
  <div
    id="mobile-menu-panel"
    class="absolute top-0 right-0 h-full w-80 max-w-[85vw] bg-secondary/95 backdrop-blur-lg border-l border-white/10 p-6"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-menu-title"
    tabindex="-1"
  >
    <h2 id="mobile-menu-title" class="sr-only">{menuLabel}</h2>
    <nav class="flex flex-col h-full" aria-label={menuLabel}>
      <!-- Close Button -->
      <div class="flex justify-end mb-8">
        <button
          id="mobile-menu-close"
          type="button"
          class="p-2 text-gray-400 hover:text-white transition-colors"
          aria-label={closeLabel}
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Navigation Links -->
      <div class="flex-1 space-y-1 overflow-y-auto">
        <a href="/" class="block py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">Anasayfa</a>
        <a href="/hizmetler/" class="block py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">Hizmetler</a>

        <!-- Bölgeler Accordion -->
        <details class="group">
          <summary class="py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors cursor-pointer list-none flex justify-between items-center">
            Bölgeler
            <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="pl-4 space-y-0.5 mt-1">
            {topDistricts.map(d => (
              <a href={`/${d.slug}/`} class="block py-2 px-4 text-sm text-gray-400 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">
                {d.name} Tabelacı
              </a>
            ))}
            <a href="/istanbul-tabelaci/" class="block py-2 px-4 text-sm text-primary font-bold hover:text-white transition-colors">
              Tüm İlçeler &rarr;
            </a>
          </div>
        </details>

        <!-- Sektörler Accordion -->
        <details class="group">
          <summary class="py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors cursor-pointer list-none flex justify-between items-center">
            Sektörler
            <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="pl-4 space-y-0.5 mt-1">
            {topSectors.map(s => (
              <a href={`/sektorel/${s.slug}/`} class="block py-2 px-4 text-sm text-gray-400 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">
                {s.icon} {s.name}
              </a>
            ))}
            <a href="/sektorel/" class="block py-2 px-4 text-sm text-primary font-bold hover:text-white transition-colors">
              Tüm Sektörler &rarr;
            </a>
          </div>
        </details>

        <a href="/galeri/" class="block py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">Galeri</a>
        <a href="/tabela-rehberi/" class="block py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">Tabela Rehberleri</a>
        <a href="/hakkimizda/" class="block py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">Hakkımızda</a>
        <a href="/sss/" class="block py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">S.S.S</a>
        <a href="/iletisim/" class="block py-3 px-4 text-lg font-medium text-gray-200 hover:text-primary hover:bg-white/5 rounded-lg transition-colors">İletişim</a>
      </div>

      <!-- Theme Toggle + Call Button (Mobile) -->
      <div class="border-t border-white/10 pt-6 mt-6">
        <div class="flex items-center gap-2 mb-4">
          <ThemeToggle lang={lang} />
        </div>

        <!-- Call Button (Mobile) -->
        <a
          href={`tel:${PHONE_TEL}`}
          data-track="call"
          data-lang={lang}
          class="block w-full text-center btn btn-primary py-3 text-sm font-bold"
        >
          {callLabel}
        </a>
      </div>
    </nav>
  </div>
</div>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const panel = document.getElementById('mobile-menu-panel');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    const closeBtn = document.getElementById('mobile-menu-close');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!toggle || !menu || !panel || !backdrop || !closeBtn) return;
    if (menu.dataset.initialized === 'true') return;
    menu.dataset.initialized = 'true';

    const openClass = 'translate-x-0';
    const closedClass = 'translate-x-full';

    function getFocusableElements() {
      return Array.from(
        panel.querySelectorAll(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      );
    }

    function openMenu() {
      menu.classList.remove(closedClass);
      menu.classList.add(openClass);
      menu.setAttribute('aria-hidden', 'false');
      menu.classList.remove('pointer-events-none');
      menu.removeAttribute('inert');
      toggle.setAttribute('aria-expanded', 'true');
      backdrop.classList.remove('opacity-0');
      backdrop.classList.add('opacity-100');
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      // Focus first focusable
      const focusable = getFocusableElements();
      const firstLink = focusable[0];
      if (firstLink) firstLink.focus();
    }

    function closeMenu() {
      menu.classList.remove(openClass);
      menu.classList.add(closedClass);
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.add('pointer-events-none');
      menu.setAttribute('inert', '');
      toggle.setAttribute('aria-expanded', 'false');
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = '';
      toggle.focus();
    }

    // Toggle button click
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close button click
    closeBtn.addEventListener('click', closeMenu);

    // Backdrop click
    backdrop.addEventListener('click', closeMenu);

    // ESC key
    document.addEventListener('keydown', (e) => {
      if (toggle.getAttribute('aria-expanded') !== 'true') return;
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        closeMenu();
        return;
      }
      if (e.key !== 'Tab') return;
      const focusable = getFocusableElements();
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    // Close on navigation (for SPA-like behavior)
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        setTimeout(closeMenu, 100);
      });
    });
  }

  // Initialize on page load
  initMobileMenu();

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initMobileMenu);

  // ============================================
  // Header Hide-on-Scroll Behavior
  // ============================================
  function initHeaderScroll() {
    const header = document.getElementById('main-header');
    if (!header) return;
    if (header.dataset.scrollInitialized === 'true') return;
    header.dataset.scrollInitialized = 'true';

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let lastScrollY = window.scrollY;
    let ticking = false;
    const SCROLL_THRESHOLD = 10; // Minimum scroll distance to trigger hide/show
    const HEADER_HEIGHT = 80; // Approximate header height

    function updateHeader() {
      const currentScrollY = window.scrollY;
      const scrollDelta = currentScrollY - lastScrollY;

      // Don't hide header if we're near the top
      if (currentScrollY < HEADER_HEIGHT) {
        header.classList.remove('header-hidden');
        header.classList.add('header-visible');
        lastScrollY = currentScrollY;
        ticking = false;
        return;
      }

      // Check if scroll distance exceeds threshold
      if (Math.abs(scrollDelta) > SCROLL_THRESHOLD) {
        if (scrollDelta > 0) {
          // Scrolling down - hide header
          header.classList.add('header-hidden');
          header.classList.remove('header-visible');
        } else {
          // Scrolling up - show header
          header.classList.remove('header-hidden');
          header.classList.add('header-visible');
        }
        lastScrollY = currentScrollY;
      }

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        if (prefersReducedMotion) {
          updateHeader();
        } else {
          requestAnimationFrame(updateHeader);
        }
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Initialize header scroll behavior
  initHeaderScroll();
  document.addEventListener('astro:page-load', initHeaderScroll);
</script>

<style>
  /* Header show/hide transitions */
  #main-header {
    transition: transform 0.3s ease-in-out;
  }

  #main-header.header-visible {
    transform: translateY(0);
  }

  #main-header.header-hidden {
    transform: translateY(-100%);
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    #main-header {
      transition: none;
    }

    #main-header.header-hidden {
      /* Instant hide for reduced motion users */
      transform: translateY(-100%);
    }
  }
</style>
