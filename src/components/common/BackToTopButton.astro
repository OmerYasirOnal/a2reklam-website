---
interface Props {
  lang?: 'tr' | 'en';
}

const { lang = 'tr' } = Astro.props;
const label = lang === 'en' ? 'Back to top' : 'Yukarı Çık';
---

<button
  type="button"
  data-back-to-top
  aria-label={label}
  aria-hidden="true"
  class="fixed z-[60] rounded-full bg-primary/80 text-secondary shadow-lg w-10 h-10 flex items-center justify-center transition-all duration-300 opacity-0 pointer-events-none hover:bg-primary hover:scale-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-secondary bottom-36 right-4 md:bottom-24 md:right-6"
>
  <span class="sr-only">{label}</span>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
  </svg>
</button>

<script>
  (() => {
    const btn = document.querySelector('[data-back-to-top]') as HTMLButtonElement | null;
    if (!btn || btn.dataset.init === '1') return;
    btn.dataset.init = '1';

    let ticking = false;
    const THRESHOLD = 400;

    const update = () => {
      const show = window.scrollY > THRESHOLD;
      btn.classList.toggle('opacity-0', !show);
      btn.classList.toggle('pointer-events-none', !show);
      btn.setAttribute('aria-hidden', String(!show));
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    update();
  })();
</script>
