---
import {
  ADDRESS,
  EMAIL,
  PHONE_NUMBER,
  PHONE_TEL,
  SOCIAL_FACEBOOK_URL,
  SOCIAL_INSTAGRAM_URL,
  SOCIAL_LINKEDIN_URL,
} from '../../consts';

const today = new Date();
interface Props {
  lang?: string;
}
const { lang = 'tr' } = Astro.props;

const content = {
  tr: {
    tagline: 'İstanbul\'da profesyonel tabela ve reklam üretim hizmetleri. 2010\'dan beri kaliteli üretim.',
    quickTitle: 'Hızlı Bağlantılar',
    quickLinks: [
      { label: 'Hizmetler', href: '/hizmetler/' },
      { label: 'Galeri', href: '/galeri/' },
      { label: 'Videolar', href: '/videolar/' },
      { label: 'Hizmet Bölgeleri', href: '/hizmet-bolgeleri/' },
      { label: 'Referanslar', href: '/referanslar/' },
      { label: 'Blog', href: '/blog/' },
      { label: 'Site Haritası', href: '/site-haritasi/' },
      { label: 'Hakkımızda', href: '/hakkimizda/' },
      { label: 'İletişim', href: '/iletisim/' },
    ],
    contactTitle: 'İletişim',
    socialTitle: 'Sosyal',
    rights: 'Tüm hakları saklıdır.',
  },
  en: {
    tagline: 'Professional signage and advertising production services in Istanbul. Quality manufacturing since 2010.',
    quickTitle: 'Quick Links',
    quickLinks: [
      { label: 'Services', href: '/en/services/' },
      { label: 'Gallery', href: '/en/gallery/' },
      { label: 'Videos', href: '/videolar/' },
      { label: 'Portfolio', href: '/en/portfolio/' },
      { label: 'Sitemap', href: '/site-haritasi/' },
      { label: 'Contact', href: '/en/contact/' },
    ],
    contactTitle: 'Contact',
    socialTitle: 'Social',
    rights: 'All rights reserved.',
  },
};

const t = lang === 'en' ? content.en : content.tr;
---

<footer class="bg-secondary/95 text-white py-16 border-t border-white/10 backdrop-blur-sm">
	<div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12">
    
    <div>
      <h3 class="font-heading font-bold text-2xl mb-6 flex items-center gap-2">
        <span class="text-primary text-3xl">A2</span> REKLAM
      </h3>
      <p class="text-gray-400 text-sm leading-relaxed max-w-xs">
        {t.tagline}
      </p>
    </div>

    <div>
      <h4 class="font-bold mb-6 text-lg border-b border-primary/30 inline-block pb-2">{t.quickTitle}</h4>
      <ul class="space-y-3 text-sm text-gray-400">
        {t.quickLinks.map((item) => (
          <li>
            <a href={item.href} class="group hover:text-primary transition-colors flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-primary rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-bold mb-6 text-lg border-b border-primary/30 inline-block pb-2">{t.contactTitle}</h4>
      <ul class="space-y-4 text-sm text-gray-400">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span>{ADDRESS}</span>
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          <a href={`tel:${PHONE_TEL}`} data-track="call" data-lang={lang} class="hover:text-white hover:underline decoration-primary">{PHONE_NUMBER}</a>
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          <a href={`mailto:${EMAIL}`} class="hover:text-white hover:underline decoration-primary">{EMAIL}</a>
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-bold mb-4">{t.socialTitle}</h4>
      <div class="flex gap-4">
        {SOCIAL_INSTAGRAM_URL && (
          <a
            href={SOCIAL_INSTAGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-track="outbound"
            data-outbound-type="social"
            data-outbound-target="instagram"
            data-outbound-name="instagram"
            data-lang={lang}
            class="opacity-80 hover:opacity-100 hover:-translate-y-0.5 transition-all focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-secondary rounded-lg p-1"
            aria-label="Instagram"
          >
            <img
              src="/assets/icons/social/instagram.svg"
              alt=""
              width="24"
              height="24"
              class="w-6 h-6"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
          </a>
        )}
        {SOCIAL_FACEBOOK_URL && (
          <a
            href={SOCIAL_FACEBOOK_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-track="outbound"
            data-outbound-type="social"
            data-outbound-target="facebook"
            data-outbound-name="facebook"
            data-lang={lang}
            class="opacity-80 hover:opacity-100 hover:-translate-y-0.5 transition-all focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-secondary rounded-lg p-1"
            aria-label="Facebook"
          >
            <img
              src="/assets/icons/social/facebook.svg"
              alt=""
              width="24"
              height="24"
              class="w-6 h-6"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
          </a>
        )}
        {SOCIAL_LINKEDIN_URL && (
          <a
            href={SOCIAL_LINKEDIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-track="outbound"
            data-outbound-type="social"
            data-outbound-target="linkedin"
            data-outbound-name="linkedin"
            data-lang={lang}
            class="opacity-80 hover:opacity-100 hover:-translate-y-0.5 transition-all focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-secondary rounded-lg p-1"
            aria-label="LinkedIn"
          >
            <img
              src="/assets/icons/social/linkedin.svg"
              alt=""
              width="24"
              height="24"
              class="w-6 h-6"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
          </a>
        )}
      </div>
    </div>

  </div>
  <div class="container mx-auto px-4 mt-8 pt-8 border-t border-gray-800 text-center text-xs text-gray-500">
    <div class="mb-2">&copy; {today.getFullYear()} A2 Reklam. {t.rights}</div>
    {lang !== 'en' && (
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
        <a href="/gizlilik-politikasi/" class="hover:text-primary transition-colors">Gizlilik Politikası</a>
        <span class="text-gray-700">&middot;</span>
        <a href="/kullanim-kosullari/" class="hover:text-primary transition-colors">Kullanım Koşulları</a>
        <span class="text-gray-700">&middot;</span>
        <a href="/cerez-politikasi/" class="hover:text-primary transition-colors">Çerez Politikası</a>
        <span class="text-gray-700">&middot;</span>
        <a href="/kvkk/" class="hover:text-primary transition-colors">KVKK</a>
      </div>
    )}
  </div>
</footer>
