---
/**
 * Breadcrumb.astro — Breadcrumb navigasyonu + BreadcrumbList schema
 * SFS +3 puan, AXS +2 puan
 *
 * Kullanım:
 * <Breadcrumb items={[
 *   { name: "Ana Sayfa", url: "/" },
 *   { name: "Hizmetler", url: "/hizmetler" },
 *   { name: "Kutu Harf" }  // son item'da url yok = aktif sayfa
 * ]} />
 *
 * Veya otomatik (sadece URL'den türetir):
 * <Breadcrumb />
 */

interface BreadcrumbItem {
  name: string;
  url?: string;
  item?: string;
}

interface Props {
  items?: BreadcrumbItem[];
}

const { items } = Astro.props;

// Otomatik breadcrumb: URL path'inden türet
function generateBreadcrumbs(): BreadcrumbItem[] {
  const path = Astro.url.pathname;
  const segments = path.split('/').filter(Boolean);

  const nameMap: Record<string, string> = {
    'hizmetler': 'Hizmetler',
    'blog': 'Blog',
    'galeri': 'Galeri',
    'iletisim': 'İletişim',
    'videolar': 'Videolar',
    'kvkk': 'KVKK',
    'bolgeler': 'Bölgeler',
    'hizmet-bolgeleri': 'Hizmet Bölgeleri',
    'istanbul-tabelaci': 'Hizmet Bölgeleri',
    'tabela-rehberi': 'Tabela Rehberi',
    'site-haritasi': 'Site Haritası',
    'hakkimizda': 'Hakkımızda',
    'sss': 'Sık Sorulan Sorular',
  };

  const crumbs: BreadcrumbItem[] = [{ name: "Ana Sayfa", url: "/" }];

  let currentPath = '';
  segments.forEach((seg, i) => {
    currentPath += `/${seg}`;
    const name = nameMap[seg] || seg
      .replace(/-/g, ' ')
      .replace(/\b\w/g, c => c.toUpperCase());

    if (i === segments.length - 1) {
      crumbs.push({ name }); // Aktif sayfa — link yok
    } else {
      crumbs.push({ name, url: currentPath });
    }
  });

  return crumbs;
}

const breadcrumbs = items || generateBreadcrumbs();
const site = Astro.site?.href || 'https://a2reklam.com';

// Normalize: accept both `url` and `item` keys
const getUrl = (crumb: BreadcrumbItem) => crumb.url || crumb.item;

// BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((crumb, index) => {
    const href = getUrl(crumb);
    const entry: any = {
      "@type": "ListItem",
      "position": index + 1,
      "name": crumb.name,
    };
    if (href) {
      entry.item = new URL(href, site).href;
    }
    return entry;
  })
};
---

{breadcrumbs.length > 1 && (
  <nav aria-label="Breadcrumb" class="breadcrumb-nav">
    <ol class="breadcrumb-list">
      {breadcrumbs.map((crumb, i) => (
        <li class="breadcrumb-item">
          {getUrl(crumb) ? (
            <a href={getUrl(crumb)} class="breadcrumb-link">{crumb.name}</a>
          ) : (
            <span class="breadcrumb-current" aria-current="page">{crumb.name}</span>
          )}
          {i < breadcrumbs.length - 1 && (
            <span class="breadcrumb-sep" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<!-- BreadcrumbList Schema -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<style>
  .breadcrumb-nav {
    padding: 0.75rem 0;
    margin-bottom: 1rem;
  }
  .breadcrumb-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8125rem;
  }
  .breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .breadcrumb-link {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb-link:hover {
    color: var(--color-primary, #C9A227);
  }
  .breadcrumb-current {
    color: rgba(255,255,255,0.8);
    font-weight: 500;
  }
  .breadcrumb-sep {
    display: flex;
    align-items: center;
    color: rgba(255,255,255,0.25);
    margin: 0 0.25rem;
  }
</style>
