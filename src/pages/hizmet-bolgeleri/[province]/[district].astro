---
import { getAllDistricts, getProvinceBySlug, LOCATIONS } from '../../../data/locations';
import Layout from '../../../layouts/Layout.astro';
import { WHATSAPP_LINK, PHONE_TEL } from '../../../consts';

export async function getStaticPaths() {
  const allDistricts = getAllDistricts();
  
  // Filter out Istanbul districts (they use the old /hizmet-bolgeleri/[slug] route)
  const nonIstanbulDistricts = allDistricts.filter(d => d.province !== 'istanbul');
  
  return nonIstanbulDistricts.map((district) => {
    const province = getProvinceBySlug(district.province);
    if (!province) return null;
    
    // Find 4 nearby districts (same province first, then others)
    const sameProvinceDistricts = allDistricts.filter(
      d => d.province === district.province && d.slug !== district.slug
    );
    const otherDistricts = allDistricts.filter(
      d => d.province !== district.province
    );
    const neighbors = [...sameProvinceDistricts, ...otherDistricts]
      .slice(0, 4)
      .map(d => ({
        name: d.trName,
        slug: d.slug,
        province: d.province,
      }));
    
    return {
      params: {
        province: district.province,
        district: district.slug,
      },
      props: {
        district,
        province,
        neighbors,
      },
    };
  }).filter(Boolean);
}

const { district, province, neighbors } = Astro.props;

const title = `${district.trName} Tabela ve Reklam Hizmetleri | A2 Reklam`;
const description = `${province.trName} ili ${district.trName} ilçesinde profesyonel tabela üretimi ve montaj hizmetleri. Cephe tabelası, totem, ışıklı tabela ve daha fazlası.`;

const breadcrumbs = [
  { name: 'Anasayfa', item: '/' },
  { name: 'Hizmet Bölgeleri', item: '/hizmet-bolgeleri/' },
  { name: province.trName, item: `/hizmet-bolgeleri/${province.slug}/` },
  { name: district.trName, item: `/hizmet-bolgeleri/${province.slug}/${district.slug}/` },
];

// Service highlights (rotate based on district hash)
const districtHash = district.slug.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
const serviceHighlights = [
  { name: 'Cephe Tabelası', slug: 'cephe-tabela', icon: '🏢' },
  { name: 'Totem Tabela', slug: 'totem', icon: '📍' },
  { name: 'Işıklı Tabela', slug: 'isikli-tabela', icon: '💡' },
  { name: 'Kutu Harf', slug: 'paslanmaz-harfler', icon: '✨' },
  { name: 'Araç Giydirme', slug: 'arac-giydirme', icon: '🚗' },
  { name: 'Yönlendirme Sistemleri', slug: 'yonlendirme', icon: '➡️' },
];
const selectedServices = [0, 1, 2, 3].map(i => serviceHighlights[(districtHash + i) % serviceHighlights.length]);

// FAQ (rotate based on district)
const faqSets = [
  [
    {
      question: `${district.trName}'da tabela montajı ne kadar sürer?`,
      answer: `${district.trName} bölgesinde standart tabela montajımız 1-3 iş günü içinde tamamlanır. Proje büyüklüğüne göre süre değişebilir.`,
    },
    {
      question: 'Hangi tabela türlerini üretiyorsunuz?',
      answer: 'Cephe tabelası, totem, ışıklı/ışıksız tabelalar, kutu harf, paslanmaz harf, araç giydirme ve özel imalat dahil tüm tabela çeşitlerini üretiyoruz.',
    },
    {
      question: 'Ücretsiz keşif hizmeti veriyor musunuz?',
      answer: `Evet, ${province.trName} genelinde ücretsiz keşif ve ölçüm hizmeti sunuyoruz. Projenizi yerinde inceleyip detaylı teklif hazırlıyoruz.`,
    },
    {
      question: 'Tabela bakım ve onarım hizmeti var mı?',
      answer: 'Evet, montaj sonrası bakım ve onarım desteği sağlıyoruz. Işık arızaları, boya yenileme ve genel bakım hizmetlerimiz mevcuttur.',
    },
  ],
  [
    {
      question: `${district.trName} bölgesinde hangi sektörlere hizmet veriyorsunuz?`,
      answer: 'Perakende, restoran, otel, sağlık, eğitim, OSB, lojistik ve tüm kurumsal sektörlere özel tabela çözümleri sunuyoruz.',
    },
    {
      question: 'Tabela tasarımı yapıyor musunuz?',
      answer: 'Evet, deneyimli tasarım ekibimiz markanıza özel tabela tasarımları hazırlıyor. Kurumsal kimliğinize uygun çözümler üretiyoruz.',
    },
    {
      question: 'Ruhsat ve izin işlemleri için destek veriyor musunuz?',
      answer: `${district.trName} belediyesi tabela ruhsatı ve gerekli izin süreçlerinde danışmanlık desteği sağlıyoruz.`,
    },
    {
      question: 'Ödeme koşullarınız nedir?',
      answer: 'Esnek ödeme seçenekleri sunuyoruz. Proje bazında %50 kapora, teslimde kalan ödeme şeklinde çalışabiliriz.',
    },
  ],
];
const faq = faqSets[districtHash % faqSets.length];
---

<Layout title={title} description={description} breadcrumbs={breadcrumbs} faq={faq}>
  <div class="relative py-24 bg-secondary overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="container mx-auto px-4 relative z-10">
      <!-- Hero Section -->
      <div class="text-center mb-16">
        <div class="inline-block mb-4 px-4 py-1 border border-primary/30 rounded-full bg-black/30 backdrop-blur text-primary text-sm font-semibold tracking-wider uppercase">
          {province.trName} / {district.trName}
        </div>
        <h1 class="font-heading font-bold text-4xl md:text-6xl mb-6 text-white uppercase tracking-tight">
          {district.trName} <span class="text-primary">TABELA</span> VE REKLAM
        </h1>
        <p class="text-gray-300 max-w-3xl mx-auto text-lg leading-relaxed">
          {province.trName} ili {district.trName} ilçesinde profesyonel tabela üretimi, tasarım ve montaj hizmetleri. 
          Kurumsal kimliğinize uygun, kaliteli ve dayanıklı tabela çözümleri sunuyoruz.
        </p>
      </div>

      <!-- Services Highlight -->
      <div class="mb-20">
        <h2 class="font-heading font-bold text-3xl md:text-4xl mb-8 text-white text-center uppercase">
          Hizmetlerimiz
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {selectedServices.map((service) => (
            <a
              href={`/hizmetler/${service.slug}/`}
              class="glass-card group p-6 text-center hover:scale-105 transition-transform"
            >
              <div class="text-4xl mb-3">{service.icon}</div>
              <h3 class="text-white font-bold text-sm md:text-base group-hover:text-primary transition-colors">
                {service.name}
              </h3>
            </a>
          ))}
        </div>
      </div>

      <!-- Process Section -->
      <div class="glass-card p-8 md:p-12 mb-20">
        <h2 class="font-heading font-bold text-3xl md:text-4xl mb-8 text-white text-center uppercase">
          Çalışma Sürecimiz
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center text-primary text-2xl font-black mx-auto mb-4">
              1
            </div>
            <h3 class="text-white font-bold mb-2">Keşif</h3>
            <p class="text-gray-300 text-sm">Ücretsiz yerinde inceleme ve ölçüm</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center text-primary text-2xl font-black mx-auto mb-4">
              2
            </div>
            <h3 class="text-white font-bold mb-2">Tasarım</h3>
            <p class="text-gray-300 text-sm">Markanıza özel tabela tasarımı</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center text-primary text-2xl font-black mx-auto mb-4">
              3
            </div>
            <h3 class="text-white font-bold mb-2">Üretim</h3>
            <p class="text-gray-300 text-sm">Kaliteli malzeme ile özenli imalat</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center text-primary text-2xl font-black mx-auto mb-4">
              4
            </div>
            <h3 class="text-white font-bold mb-2">Montaj</h3>
            <p class="text-gray-300 text-sm">Profesyonel kurulum ve test</p>
          </div>
        </div>
      </div>

      <!-- Why A2 Reklam -->
      <div class="mb-20">
        <h2 class="font-heading font-bold text-3xl md:text-4xl mb-8 text-white text-center uppercase">
          Neden <span class="text-primary">A2 Reklam</span>?
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="glass-card p-6">
            <div class="text-primary text-3xl mb-3">✓</div>
            <h3 class="text-white font-bold mb-2">14+ Yıl Tecrübe</h3>
            <p class="text-gray-300 text-sm">2010'dan beri sektörde güvenilir hizmet</p>
          </div>
          <div class="glass-card p-6">
            <div class="text-primary text-3xl mb-3">✓</div>
            <h3 class="text-white font-bold mb-2">Kaliteli Üretim</h3>
            <p class="text-gray-300 text-sm">Dayanıklı malzeme ve özenli işçilik</p>
          </div>
          <div class="glass-card p-6">
            <div class="text-primary text-3xl mb-3">✓</div>
            <h3 class="text-white font-bold mb-2">Hızlı Montaj</h3>
            <p class="text-gray-300 text-sm">Zamanında teslimat garantisi</p>
          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="glass-card p-8 md:p-12 text-center mb-20">
        <h2 class="font-heading font-bold text-3xl md:text-4xl mb-4 text-white uppercase">
          Hemen <span class="text-primary">Teklif Alın</span>
        </h2>
        <p class="text-gray-300 mb-8 max-w-2xl mx-auto">
          {district.trName} bölgesindeki projeniz için ücretsiz keşif ve detaylı teklif almak için bizimle iletişime geçin.
        </p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
          <a
            href={WHATSAPP_LINK}
            target="_blank"
            rel="noopener noreferrer"
            data-track="whatsapp"
            data-lang="tr"
            class="btn btn-primary px-8 py-4 text-lg font-bold uppercase"
          >
            WhatsApp ile İletişim
          </a>
          <a
            href={`tel:${PHONE_TEL}`}
            data-track="call"
            data-lang="tr"
            class="btn btn-secondary px-8 py-4 text-lg font-bold uppercase"
          >
            Hemen Ara
          </a>
        </div>
      </div>

      <!-- Nearby Districts -->
      {neighbors.length > 0 && (
        <div>
          <h2 class="font-heading font-bold text-3xl md:text-4xl mb-8 text-white text-center uppercase">
            Yakın Bölgeler
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {neighbors.map((neighbor) => (
              <a
                href={`/hizmet-bolgeleri/${neighbor.province}/${neighbor.slug}/`}
                class="glass-card p-4 text-center hover:scale-105 transition-transform"
              >
                <span class="text-white font-bold text-sm">{neighbor.name}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>
