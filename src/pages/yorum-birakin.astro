---
import Layout from '../layouts/Layout.astro';
import { PHONE_NUMBER, PHONE_TEL, GOOGLE_RATING, GOOGLE_REVIEW_COUNT, MAPS_URL } from '../consts';

// Google Business Profile direkt review linki
// Place ID: 0x14cab7540b4f6ebf:0x477fa2bd2bae8a19 (A2 Reklam Tabela & Mimari Yönlendirme)
const GOOGLE_REVIEW_URL = 'https://search.google.com/local/writereview?placeid=ChIJv25PC1S3yhQRGYquK72if0c';

const breadcrumbs = [
  { name: 'Anasayfa', item: '/' },
  { name: 'Yorum Bırakın', item: '/yorum-birakin/' },
];

const faq = [
  {
    question: 'Yorumum ne kadar sürede yayınlanır?',
    answer: 'Google yorumlarınız genellikle birkaç dakika içinde yayınlanır. Bazı durumlarda Google otomatik spam kontrolü için 24 saate kadar inceleme sürebilir.',
  },
  {
    question: 'Yorumum için ücret veya ödül alabilir miyim?',
    answer: 'Hayır. Google politikaları gereği yorumlar karşılığında ödül sunmak yasaktır. Ancak içten bir değerlendirme bizim için çok değerlidir ve her yoruma teşekkür ederiz.',
  },
  {
    question: 'Fotoğraf ekleyebilir miyim?',
    answer: 'Evet. Yorum yazarken "Fotoğraf ekle" butonuyla tamamlanmış projenizi gösteren fotoğraflar ekleyebilirsiniz. Fotoğraflı yorumlar Google\'da daha çok görüntülenir.',
  },
  {
    question: 'Yorum yazmak için Google hesabı şart mı?',
    answer: 'Evet, Google yorum sistemi sadece Google hesabı olanların yorum yapmasına izin verir. Telefon numaranızla ücretsiz Google hesabı oluşturabilirsiniz.',
  },
];
---

<Layout
  title="Yorum Bırakın | A2 Reklam"
  description="A2 Reklam ile çalıştıysanız Google yorumunuzu bırakarak diğer müşterilere yol gösterin. Her yorumunuz bizim için çok değerli."
  breadcrumbs={breadcrumbs}
  faq={faq}
  noindex={true}
>
  <!-- Noindex çünkü bu bir conversion landing — SEO hedefi yok -->

  <section class="py-20 bg-secondary">
    <div class="max-w-2xl mx-auto px-4 text-center">

      <!-- Hero -->
      <div class="mb-10">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-primary/10 rounded-full mb-6">
          <svg class="w-12 h-12 text-primary" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
          </svg>
        </div>
        <h1 class="text-4xl md:text-5xl font-heading font-bold text-white mb-4">
          Deneyiminizi Paylaşın
        </h1>
        <p class="text-xl text-gray-400 leading-relaxed">
          A2 Reklam'ı tercih ettiğiniz için teşekkürler.<br />
          Yorumunuz bizi daha iyi hizmet vermeye teşvik ediyor.
        </p>
      </div>

      <!-- Social Proof -->
      <div class="mb-10 p-6 bg-accent-light rounded-2xl border border-white/5">
        <div class="flex items-center justify-center gap-2 mb-2">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="w-8 h-8 text-primary fill-current" viewBox="0 0 24 24">
              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
            </svg>
          ))}
        </div>
        <div class="text-3xl font-bold text-white">{GOOGLE_RATING}/5</div>
        <div class="text-gray-400 text-sm">
          {GOOGLE_REVIEW_COUNT}+ müşterimizin ortalama değerlendirmesi
        </div>
      </div>

      <!-- Ana CTA -->
      <a
        href={GOOGLE_REVIEW_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-3 bg-primary hover:bg-white text-secondary font-bold py-5 px-10 rounded-xl text-lg transition-all transform hover:-translate-y-1 shadow-xl shadow-primary/30 mb-4"
        data-track="google_review_click"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Google'da Yorum Bırak
      </a>

      <p class="text-sm text-gray-500 mb-8">
        Butona bastığınızda Google yorum formu yeni sekmede açılır.<br />
        Sadece 1 dakikanızı alır.
      </p>

      <!-- Alternatif İletişim -->
      <div class="p-6 bg-accent-light rounded-2xl border border-white/5 text-left">
        <h3 class="text-white font-heading font-bold text-lg mb-4 flex items-center gap-2">
          <span class="w-1 h-6 bg-primary block rounded-full"></span>
          Yoruma vaktin yok mu? Bize direkt ulaş
        </h3>
        <div class="space-y-3">
          <a href={`tel:${PHONE_TEL}`} class="flex items-center gap-3 text-gray-300 hover:text-primary transition-colors">
            <span class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center text-primary">☎</span>
            <span>{PHONE_NUMBER}</span>
          </a>
          <a href="https://wa.me/905316181672" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-gray-300 hover:text-primary transition-colors">
            <span class="w-10 h-10 bg-green-600/20 rounded-full flex items-center justify-center">💬</span>
            <span>WhatsApp ile mesaj gönder</span>
          </a>
          <a href="mailto:info@a2reklam.com" class="flex items-center gap-3 text-gray-300 hover:text-primary transition-colors">
            <span class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center text-primary">✉</span>
            <span>info@a2reklam.com</span>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Tracking için özel script -->
  <script>
    document.querySelectorAll('[data-track="google_review_click"]').forEach(el => {
      el.addEventListener('click', () => {
        if (typeof window.dataLayer !== 'undefined') {
          window.dataLayer.push({
            event: 'google_review_click',
            event_category: 'engagement',
            event_label: 'review_landing',
          });
        }
      });
    });
  </script>
</Layout>
