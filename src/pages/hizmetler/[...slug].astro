---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { loadImagesManifest } from '../../utils/imagesManifest';
import { buildImageAlt } from '../../utils/imageSeo';
import { PHONE_NUMBER, PHONE_TEL } from '../../consts';
import { buildWhatsAppLink, buildWhatsAppMessage } from '../../utils/whatsapp';
import Gallery from '../../components/common/Gallery.astro';
import { getServiceLabel } from '../../config/serviceLabels';
import { getServiceSchema } from '../../utils/serviceSchema';
import CallBand from '../../components/common/CallBand.astro';

export async function getStaticPaths() {
  const services = await getCollection('services');

  // Load manifest for images
  const manifest = loadImagesManifest();

  return services.map(entry => {
    // Filter images for this category
    const categoryImages = manifest.filter((m: any) => m.category === entry.slug);
    
    return {
      params: { slug: entry.slug },
      props: { entry, images: categoryImages },
    };
  });
}

const { entry, images } = Astro.props;
const { Content } = await entry.render();
const displayTitle = getServiceLabel(entry.slug, 'tr') ?? entry.data.title;
const relatedPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const metaTitle = `${displayTitle} | Kurumsal Tabela Çözümleri - A2 Reklam`;
const metaDescription = `${entry.data.description} İstanbul genelinde keşif, üretim ve montaj için hızlı teklif alın.`;
const breadcrumbs = [
  { name: 'Anasayfa', item: '/' },
  { name: 'Hizmetler', item: '/hizmetler/' },
  { name: displayTitle, item: `/hizmetler/${entry.slug}/` },
];

const microAnswerLines = [
  { text: `${entry.data.title} markanızın görünürlüğünü artıran kurumsal tabela çözümüdür.` },
  { text: 'Perakende, ofis, üretim tesisi ve kurumsal kampüs projeleri için uygundur.' },
  { text: 'Keşif, tasarım, üretim ve montaj sürecini tek ekip yönetir.' },
  { text: 'Teslim takvimi ölçü ve malzeme netleşince planlanır.' },
  { text: 'İstanbul genelinde saha keşfi ve uygulama desteği verilir.' },
  { text: 'Teklif için formu doldurun veya doğrudan arayın.', cta: true },
];
const quickFacts = [
  { label: 'Hizmet Kapsamı', value: 'Keşif, tasarım, üretim ve montaj.' },
  { label: 'Uygulama Alanı', value: 'İç ve dış mekan projeleri.' },
  { label: 'Teslim Süresi', value: 'Ölçü ve malzeme netleşince planlanır.' },
];
const useCases = [
  'Zincir mağaza ve perakende şubeleri',
  'Otel, hastane ve sağlık kuruluşları',
  'Fabrika, üretim tesisi ve depolar',
  'Plaza, ofis ve showroom projeleri',
  'Eğitim kurumları ve kamu binaları',
];
const materials = [
  'Paslanmaz çelik, alüminyum ve kompozit panel',
  'Pleksi ve akrilik yüzeyler',
  'LED aydınlatma ve güç altyapısı',
  'Vinil, folyo ve UV baskı uygulamaları',
  'Cam, ahşap ve özel kaplamalar',
];
const processSteps = [
  'Keşif ve ihtiyaç analizi',
  'Tasarım ve teknik onay',
  'Üretim ve kalite kontrol',
  'Montaj ve teslim',
];
const pricingFactors = [
  'Ölçüler ve montaj yüksekliği',
  'Malzeme seçimi (alüminyum, paslanmaz, pleksi vb.)',
  'Aydınlatma tipi ve güç altyapısı',
  'Adet ve montaj lokasyonu',
  'Özel üretim ve hızlandırılmış teslimat ihtiyaçları',
];
const warrantyNote = 'Malzeme ve işçilik için proje bazlı garanti ve bakım planı sunarız; koşullar uygulama ihtiyaçlarına göre netleştirilir.';
const faq = [
  {
    question: `${entry.data.title} için üretim süresi ne kadar?`,
    answer: 'Keşif ve teknik detaylar netleşince üretim planı çıkarılır; acil projeler için hızlandırılmış süreç sunabiliriz.',
  },
  {
    question: 'Montaj hizmeti veriyor musunuz?',
    answer: 'Evet, İstanbul genelinde kendi ekibimizle güvenli montaj hizmeti sağlıyoruz.',
  },
  {
    question: 'Kurumsal projelerde tasarım onayı nasıl ilerliyor?',
    answer: 'Tasarım seçeneklerini marka kimliğine göre hazırlıyor, ölçü ve aplikasyon detaylarını onayınıza sunuyoruz.',
  },
  {
    question: 'Garanti ve bakım desteği var mı?',
    answer: 'Malzeme ve işçilik için projeye özel garanti ve bakım seçenekleri sunuyoruz; planlar uygulama detaylarına göre belirlenir.',
  },
  {
    question: 'Keşif sürecinde hangi bilgiler gerekli?',
    answer: 'Konum, ölçüler, kullanım amacı, aydınlatma gereksinimi ve marka standartları keşifte netleştirilir.',
  },
];
const topDistricts = [
  { label: 'Kâğıthane', href: '/kagithane-tabelaci/' },
  { label: 'Şişli', href: '/sisli-tabelaci/' },
  { label: 'Beşiktaş', href: '/besiktas-tabelaci/' },
  { label: 'Kadıköy', href: '/kadikoy-tabelaci/' },
  { label: 'Başakşehir', href: '/basaksehir-tabelaci/' },
  { label: 'Ümraniye', href: '/umraniye-tabelaci/' },
];
const whatsappMessage = buildWhatsAppMessage({ lang: 'tr', pageTitle: displayTitle });
const whatsappLink = buildWhatsAppLink(whatsappMessage);

const serviceSchema = Astro.site
  ? getServiceSchema({
      slug: entry.slug,
      title: entry.data.title,
      description: entry.data.description,
      heroImage: entry.data.heroImage,
      siteUrl: Astro.site.toString(),
    })
  : null;
---

<Layout
  title={metaTitle}
  description={metaDescription}
  lang="tr"
  image={entry.data.heroImage}
  breadcrumbs={breadcrumbs}
  faq={faq}
  whatsappTitle={entry.data.title}
>
  <!-- Hero Section - Theme-agnostic styling for consistent readability -->
  <div class="service-hero relative h-[50vh] flex items-center justify-center">
    <div class="absolute inset-0 z-0">
      <img src={entry.data.heroImage} alt={`${displayTitle} - İstanbul profesyonel tabela hizmeti | A2 Reklam`} class="w-full h-full object-cover service-hero-img" loading="eager" fetchpriority="high" decoding="async" width="1920" height="1080" />
      <!-- Theme-agnostic dark gradient overlay for text readability -->
      <div class="service-hero-overlay absolute inset-0"></div>
    </div>
    <div class="relative z-10 container mx-auto px-4 mt-20">
      <h1 class="service-hero-title font-heading font-bold text-4xl md:text-6xl mb-4">{displayTitle}</h1>
      <ul class="flex gap-2 text-sm font-medium tracking-wide service-hero-breadcrumbs">
        <li><a href="/" class="hover:text-primary transition-colors">Anasayfa</a></li>
        <li>/</li>
        <li><a href="/hizmetler/" class="hover:text-primary transition-colors">Hizmetler</a></li>
        <li>/</li>
        <li class="text-primary">{displayTitle}</li>
      </ul>
    </div>
  </div>

  <style>
    /* ============================================
       SERVICE HERO - Theme-Agnostic Styling
       Text/overlay stay consistent across dark/light
       ============================================ */

    .service-hero-img {
      opacity: 0.85;
    }

    /* Theme-agnostic dark gradient overlay for consistent text readability */
    .service-hero-overlay {
      background: linear-gradient(
        to bottom,
        rgba(11, 15, 20, 0.4) 0%,
        rgba(11, 15, 20, 0.6) 40%,
        rgba(11, 15, 20, 0.8) 100%
      );
    }

    /* Hero Title - Always white with strong shadow */
    .service-hero-title {
      color: #FFFFFF !important;
      text-shadow:
        0 2px 4px rgba(0, 0, 0, 0.8),
        0 4px 20px rgba(0, 0, 0, 0.6);
    }

    /* Breadcrumbs - Always light gray */
    .service-hero-breadcrumbs {
      color: #E5E7EB !important;
    }

    .service-hero-breadcrumbs li {
      color: #E5E7EB !important;
    }
  </style>

  <div class="container mx-auto px-4 py-20 grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_300px] gap-8 lg:gap-12">
    <!-- Main Content -->
    <div class="prose prose-lg prose-invert max-w-none prose-headings:font-heading prose-headings:font-semibold prose-a:text-primary prose-strong:text-white">
      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h2 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Hızlı Yanıt
        </h2>
        <ul class="space-y-3 text-gray-300 text-sm">
          {microAnswerLines.map((line) => (
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 bg-primary rounded-full mt-2"></span>
              <span>
                {line.text}
                {line.cta && (
                  <>
                    {' '}
                    <a href="/iletisim/" class="text-primary hover:text-primary-hover">İletişim</a>
                  </>
                )}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Gallery Grid - Positioned high for visual impact -->
      {images.length > 0 && (
        <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
          <h2 class="font-heading font-bold text-2xl mb-6 text-white flex items-center gap-2">
            <span class="w-1 h-8 bg-primary block rounded-full"></span>
            Proje Galerisi
          </h2>
          <Gallery
            images={images.map((img: any) => ({
              paths: img.paths,
              category: img.category,
              alt: buildImageAlt({ category: entry.slug, lang: 'tr' }),
            }))}
            lang="tr"
            category={entry.slug}
            initialLimit={6}
            aspectRatio="square"
          />
        </div>
      )}

      <Content />
      
      {entry.data.features && (
        <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
          <h3 class="font-heading font-bold text-2xl mb-6 text-white flex items-center gap-2">
            <span class="w-1 h-8 bg-primary block rounded-full"></span>
            Özellikler
          </h3>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {entry.data.features.map((f: string) => (
              <li class="flex items-center gap-3 text-gray-300">
                <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-primary shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                {f}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Telefon CTA Band -->
      <div class="not-prose">
        <CallBand context={entry.data.title} />
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Hızlı Bilgiler
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {quickFacts.map((fact) => (
            <div class="bg-secondary/60 rounded-lg p-4 border border-white/5">
              <div class="text-xs text-gray-400 uppercase tracking-widest">{fact.label}</div>
              <div class="text-white font-semibold mt-2">{fact.value}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Kurumsal Kullanım Alanları
        </h3>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-300 text-sm">
          {useCases.map((item) => (
            <li class="flex items-start gap-2">
              <span class="w-2 h-2 bg-primary rounded-full mt-2"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Malzeme ve Seçenekler
        </h3>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-300 text-sm">
          {materials.map((item) => (
            <li class="flex items-start gap-2">
              <span class="w-2 h-2 bg-primary rounded-full mt-2"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Süreç
        </h3>
        <ol class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-300 text-sm list-decimal list-inside">
          {processSteps.map((item) => (
            <li>{item}</li>
          ))}
        </ol>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Garanti ve Bakım
        </h3>
        <p class="text-gray-300 text-sm">{warrantyNote}</p>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Fiyatı Etkileyen Unsurlar
        </h3>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-300 text-sm">
          {pricingFactors.map((item) => (
            <li class="flex items-start gap-2">
              <span class="w-2 h-2 bg-primary rounded-full mt-2"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-6 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Sık Sorulan Sorular
        </h3>
        <div class="space-y-5">
          {faq.map((item) => (
            <div class="border border-white/5 rounded-lg p-4 bg-secondary/60">
              <h4 class="text-white font-semibold">{item.question}</h4>
              <p class="text-gray-400 text-sm mt-2">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          İstanbul'da Öne Çıkan Hizmet Bölgeleri
        </h3>
        <div class="flex flex-wrap gap-3">
          {topDistricts.map((district) => (
            <a href={district.href} class="px-4 py-2 rounded-full border border-white/10 text-sm text-gray-300 hover:border-primary/60 hover:text-white transition-colors">
              {district.label}
            </a>
          ))}
        </div>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          İlgili Blog Yazıları
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="block bg-secondary/60 border border-white/5 rounded-lg p-4 text-gray-300 hover:text-white hover:border-primary/50 transition-colors">
              <div class="text-sm font-semibold">{post.data.title}</div>
              <div class="text-xs text-gray-500 mt-2">{post.data.description}</div>
            </a>
          ))}
        </div>
      </div>

      <div class="my-10 bg-accent-light p-8 rounded-xl border border-white/5 shadow-inner not-prose">
        <h3 class="font-heading font-bold text-2xl mb-4 text-white flex items-center gap-2">
          <span class="w-1 h-8 bg-primary block rounded-full"></span>
          Hemen Teklif ve Keşif
        </h3>
        <p class="text-gray-300 text-sm mb-6">
          Projeniz için hızlı teklif almak veya ücretsiz keşif planlamak isterseniz ekibimizle iletişime geçebilirsiniz.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/iletisim/" data-track="quote" data-lang="tr" class="bg-primary text-secondary font-bold py-3 px-6 rounded-lg hover:bg-white transition-all">
            Teklif Al
          </a>
          <a href={`tel:${PHONE_TEL}`} data-track="call" data-lang="tr" class="border border-white/20 text-white font-bold py-3 px-6 rounded-lg hover:border-white transition-all">
            Ara: {PHONE_NUMBER}
          </a>
          <a href={whatsappLink} data-track="whatsapp" data-lang="tr" class="bg-green-600 text-white font-bold py-3 px-6 rounded-lg hover:bg-green-500 transition-all">
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="hidden lg:block">
      <div class="sticky top-24 space-y-6">
        <!-- CTA Widget -->
        <div class="bg-accent-light p-6 rounded-xl border border-white/5 shadow-2xl text-center">
          <h3 class="font-heading font-bold text-lg mb-3 text-white uppercase tracking-tight">Hemen Teklif <span class="text-primary">Alın</span></h3>
          <p class="text-gray-400 mb-5 text-sm leading-relaxed">
            {entry.data.title} için profesyonel destek ve fiyat teklifi alın.
          </p>
          <a href="/iletisim/" data-track="quote" data-lang="tr" class="block w-full text-center bg-primary text-secondary font-black py-3 rounded-lg hover:bg-white transition-all transform hover:-translate-y-1 shadow-lg shadow-primary/20 uppercase tracking-widest text-sm mb-3">
            Teklif İste
          </a>
          <a href={whatsappLink} data-track="whatsapp" data-lang="tr" class="flex items-center justify-center gap-2 w-full text-center bg-green-600 text-white font-bold py-3 rounded-lg hover:bg-green-500 transition-all border border-green-500/50 text-sm">
            <img src="/assets/icons/social/whatsapp-white.svg" alt="" width="20" height="20" class="w-5 h-5" loading="lazy" decoding="async" aria-hidden="true" />
            WhatsApp
          </a>
        </div>

        <!-- Diğer Hizmetler Widget -->
        <div class="glass-card p-5">
          <h3 class="font-heading font-bold text-base text-heading mb-3">Diğer Hizmetler</h3>
          <div class="space-y-2">
            {[
              { label: 'Işıklı Tabela', href: '/hizmetler/isikli-tabela/' },
              { label: 'Işıksız Tabela', href: '/hizmetler/isiksiz-tabela/' },
              { label: 'Paslanmaz Harf', href: '/hizmetler/paslanmaz-harfler/' },
              { label: 'Totem Tabela', href: '/hizmetler/totem/' },
              { label: 'Cephe Tabela', href: '/hizmetler/cephe-tabela/' },
              { label: 'Araç Giydirme', href: '/hizmetler/arac-giydirme/' },
              { label: 'Yönlendirme', href: '/hizmetler/yonlendirme/' },
            ].filter(s => !s.href.includes(entry.slug)).slice(0, 5).map(service => (
              <a href={service.href} class="flex items-center justify-between text-sm text-gray-300 hover:text-primary transition-colors py-1">
                <span>{service.label}</span>
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Sektörel Tabelalar Widget -->
        <div class="glass-card p-5">
          <h3 class="font-heading font-bold text-base text-heading mb-3">Sektörel Çözümler</h3>
          <div class="space-y-2">
            {[
              { icon: '💈', label: 'Berber Tabelası', href: '/sektorel/berber-tabelasi/' },
              { icon: '💊', label: 'Eczane Tabelası', href: '/sektorel/eczane-tabelasi/' },
              { icon: '☕', label: 'Cafe Tabelası', href: '/sektorel/cafe-restoran-tabelasi/' },
              { icon: '🏢', label: 'Plaza Tabelası', href: '/sektorel/plaza-tabelasi/' },
              { icon: '🏭', label: 'Fabrika Tabelası', href: '/sektorel/fabrika-tabelasi/' },
            ].map(s => (
              <a href={s.href} class="flex items-center justify-between text-sm text-gray-300 hover:text-primary transition-colors py-1">
                <span>{s.icon} {s.label}</span>
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            ))}
            <a href="/sektorel/" class="block text-primary text-sm font-bold hover:text-white transition-colors mt-2">
              Tüm Sektörler →
            </a>
          </div>
        </div>
      </div>
    </aside>
  </div>

{serviceSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
)}
</Layout>
