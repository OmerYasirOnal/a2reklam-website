---
import Layout from '../layouts/Layout.astro';
import { districts } from '../data/districts';
import { PHONE_TEL } from '../consts';
import CallBand from '../components/common/CallBand.astro';

export function getStaticPaths() {
  return districts.map((district) => ({
    params: { district: district.slug },
    props: { district },
  }));
}

const { district } = Astro.props;

const breadcrumbs = [
  { name: 'Anasayfa', item: '/' },
  { name: 'Hizmet Bölgeleri', item: '/istanbul-tabelaci/' },
  { name: `${district.name} Tabelacı`, item: `/${district.slug}/` },
];

// B7: Coğrafi yakınlığa göre sıralama
const nearbyDistricts = districts
  .filter(d => d.slug !== district.slug)
  .sort((a, b) => {
    const distA = Math.abs(a.coordinates.lat - district.coordinates.lat) +
                  Math.abs(a.coordinates.lng - district.coordinates.lng);
    const distB = Math.abs(b.coordinates.lat - district.coordinates.lat) +
                  Math.abs(b.coordinates.lng - district.coordinates.lng);
    return distA - distB;
  })
  .slice(0, 8);

// B3: Tüm diğer ilçeler (sayfa altı internal linking)
const allOtherDistricts = districts.filter(d => d.slug !== district.slug);

const whatsappLink = `https://wa.me/905316181672?text=Merhaba, ${encodeURIComponent(district.name)} bölgesinde tabela hizmeti almak istiyorum.`;

// Hero görseli — ilçe slug hash'ine göre gerçek proje fotoğrafından seçilir
const heroImages = [
  '/assets/img/cephe-tabela/a2reklam-cephe-tabela-001-960.webp',
  '/assets/img/paslanmaz-harfler/a2reklam-paslanmaz-harfler-002-960.webp',
  '/assets/img/totem/a2reklam-totem-003-960.webp',
  '/assets/img/isikli-isiksiz-tabelalar/a2reklam-isikli-isiksiz-tabelalar-004-960.webp',
  '/assets/img/fener-tabela/a2reklam-fener-tabela-005-960.webp',
  '/assets/img/cephe-tabela/a2reklam-cephe-tabela-006-960.webp',
  '/assets/img/paslanmaz-harfler/a2reklam-paslanmaz-harfler-007-960.webp',
  '/assets/img/ozel-imalatlar/a2reklam-ozel-imalatlar-003-960.webp',
  '/assets/img/cati-tabelasi/a2reklam-cati-tabelasi-002-960.webp',
  '/assets/img/arac-giydirme/a2reklam-arac-giydirme-004-960.webp',
  '/assets/img/totem/a2reklam-totem-005-960.webp',
  '/assets/img/isikli-isiksiz-tabelalar/a2reklam-isikli-isiksiz-tabelalar-002-960.webp',
];
const heroHash = district.slug.split('').reduce((a: number, c: string) => a + c.charCodeAt(0), 0);
const heroImage = heroImages[heroHash % heroImages.length];

const serviceLinks = [
  { title: 'Kutu Harf Tabela', href: '/hizmetler/paslanmaz-harfler/', desc: 'LED aydınlatmalı 3D harf' },
  { title: 'Işıklı Tabela', href: '/hizmetler/isikli-tabela/', desc: 'Cephe ve vitrin aydınlatma' },
  { title: 'Totem Tabela', href: '/hizmetler/totem/', desc: 'Serbest duran yönlendirme' },
  { title: 'Cephe Giydirme', href: '/hizmetler/cephe-tabela/', desc: 'Kompozit ve dibond uygulama' },
  { title: 'Araç Giydirme', href: '/hizmetler/arac-giydirme/', desc: 'Tam/yarım araç kaplama' },
  { title: 'Yönlendirme', href: '/hizmetler/yonlendirme/', desc: 'İç ve dış mekan yönlendirme' },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Tabela İmalatı ve Montaj",
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://a2reklam.com/#organization"
  },
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": `${district.name}, İstanbul`
  },
  "description": `${district.name} bölgesinde profesyonel tabela imalatı, montaj ve bakım hizmetleri.`,
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "TRY",
    "lowPrice": "8000",
    "highPrice": "150000"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://a2reklam.com/#organization",
  "name": "A2 Reklam",
  "url": "https://a2reklam.com",
  "telephone": "+905316181672",
  "image": "https://a2reklam.com/brand/a2reklam-logo.png",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Şirintepe, Açelya Sokağı Ugur Apt No:4/a",
    "addressLocality": "Kağıthane",
    "addressRegion": "İstanbul",
    "postalCode": "34415",
    "addressCountry": "TR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 41.0820,
    "longitude": 28.9730
  },
  "areaServed": {
    "@type": "City",
    "name": district.name + ", İstanbul"
  },
  "priceRange": "₺₺",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "127",
    "bestRating": "5"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
    "opens": "09:00",
    "closes": "18:00"
  }
};
---

<Layout
  title={district.title}
  description={district.metaDescription}
  breadcrumbs={breadcrumbs}
  faq={district.content.faq}
  whatsappTitle={district.title}
  whatsappLocation={district.name}
>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-gray-400">
        <li><a href="/" class="hover:text-primary transition-colors">Ana Sayfa</a></li>
        <li class="text-gray-600">/</li>
        <li><a href="/istanbul-tabelaci/" class="hover:text-primary transition-colors">Hizmet Bölgeleri</a></li>
        <li class="text-gray-600">/</li>
        <li class="text-primary">{district.name}</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Ana İçerik -->
      <div class="lg:col-span-2">

        <!-- Hero Görsel -->
        <div class="mb-8 rounded-xl overflow-hidden border border-white/10">
          <img
            src={heroImage}
            alt={`${district.name} tabela imalatı — A2 Reklam proje örneği`}
            width="960"
            height="540"
            class="w-full h-48 md:h-64 object-cover"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>

        <h1 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
          {district.h1}
        </h1>

        <!-- Güven Sinyalleri (Ads Landing Page) -->
        <div class="flex flex-wrap items-center gap-4 mb-6 text-sm">
          <span class="flex items-center gap-1.5 text-primary font-bold">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            5.0 Google
          </span>
          <span class="text-gray-400">|</span>
          <span class="text-gray-300"><strong class="text-white">2500+</strong> Proje</span>
          <span class="text-gray-400">|</span>
          <span class="text-gray-300"><strong class="text-white">20+</strong> Yıl Deneyim</span>
          <span class="text-gray-400">|</span>
          <span class="text-gray-300"><strong class="text-white">39</strong> İlçede Hizmet</span>
        </div>

        <!-- BÜYÜK TELEFON CTA (tüm ekranlarda, lokasyon odaklı) -->
        <div class="mb-10 p-6 md:p-8 bg-gradient-to-br from-primary/20 via-primary/10 to-transparent border-2 border-primary/40 rounded-2xl">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-5">
            <div class="text-center md:text-left">
              <p class="text-white font-heading font-bold text-xl md:text-2xl mb-1">
                {district.name} Tabelacı · <span class="text-primary">Hemen Arayın</span>
              </p>
              <p class="text-gray-300 text-sm md:text-base">
                Ücretsiz keşif · 48 saatte teklif · 2 yıl garanti
              </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-3 md:flex-shrink-0">
              <a
                href={`tel:${PHONE_TEL}`}
                data-track="call"
                data-lang="tr"
                class="group inline-flex items-center justify-center gap-3 bg-primary text-secondary font-black px-5 py-4 rounded-xl shadow-lg shadow-primary/40 hover:bg-white transition-all"
                aria-label="Hemen ara"
              >
                <svg class="w-5 h-5 animate-pulse" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57-.35-.11-.74-.03-1.02.24l-2.2 2.2c-2.83-1.44-5.15-3.75-6.59-6.58l2.2-2.21c.27-.27.35-.67.24-1.02A11.36 11.36 0 013.5 4c0-.55-.45-1-1-1H1c-.55 0-1 .45-1 1 0 10.51 8.49 19 19 19 .55 0 1-.45 1-1v-1.5c0-.55-.45-1-1-1z"/>
                </svg>
                <div class="flex flex-col items-start leading-tight">
                  <span class="text-[10px] uppercase tracking-widest opacity-80">Hemen Ara</span>
                  <span class="text-lg md:text-xl font-black">0531 618 16 72</span>
                </div>
              </a>
              <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-green-600 text-white font-bold px-5 py-4 rounded-xl hover:bg-green-700 transition-all">
                <img src="/assets/icons/social/whatsapp-white.svg" alt="" width="20" height="20" class="w-5 h-5" loading="lazy" decoding="async" aria-hidden="true" />
                WhatsApp
              </a>
            </div>
          </div>
        </div>

        <!-- İçerik -->
        <div class="prose prose-invert prose-lg max-w-none mb-12">
          {district.content.intro.split('\n\n').map((paragraph: string) => (
            <p class="text-gray-300 leading-relaxed mb-4">{paragraph}</p>
          ))}
        </div>

        <!-- Hizmetlerimiz Grid -->
        <section class="mb-12">
          <h2 class="font-heading text-2xl font-bold text-white mb-6">
            {district.name}'de Sunduğumuz Tabela Hizmetleri
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {serviceLinks.map(service => (
              <a href={service.href} class="glass-card p-4 hover:border-primary/50 transition-all group">
                <h3 class="font-bold text-white group-hover:text-primary transition-colors">{service.title}</h3>
                <p class="text-gray-400 text-sm mt-1">{service.desc}</p>
              </a>
            ))}
          </div>
        </section>

        <!-- Ticari Bölgeler -->
        {district.content.commercialAreas.length > 0 && (
          <section class="mb-12">
            <h2 class="font-heading text-2xl font-bold text-white mb-4">
              {district.name}'de Hizmet Verdiğimiz Bölgeler
            </h2>
            <div class="flex flex-wrap gap-2">
              {district.content.commercialAreas.map((area: string) => (
                <span class="bg-accent-light text-gray-300 px-3 py-1.5 rounded-lg text-sm border border-white/5">
                  {area}
                </span>
              ))}
            </div>
          </section>
        )}

        <!-- Neden A2 Reklam? -->
        <section class="mb-12">
          <h2 class="font-heading text-2xl font-bold text-white mb-6">
            {district.name}'de Neden A2 Reklam?
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="glass-card p-5">
              <div class="text-primary text-2xl mb-2">🏭</div>
              <h3 class="font-bold text-white mb-2">Kendi Üretim Tesisimiz</h3>
              <p class="text-gray-400 text-sm">Aracı firma olmadan, kendi atölyemizde üretim yapıyoruz. Bu sayede hem fiyat hem kalite avantajı sağlıyoruz.</p>
            </div>
            <div class="glass-card p-5">
              <div class="text-primary text-2xl mb-2">📐</div>
              <h3 class="font-bold text-white mb-2">Ücretsiz Keşif ve Tasarım</h3>
              <p class="text-gray-400 text-sm">{district.name} bölgesine ücretsiz keşif ekibi gönderiyoruz. Yerinde ölçüm ve 3D tasarım sunuyoruz.</p>
            </div>
            <div class="glass-card p-5">
              <div class="text-primary text-2xl mb-2">⚡</div>
              <h3 class="font-bold text-white mb-2">Hızlı Teslimat</h3>
              <p class="text-gray-400 text-sm">Keşiften montaja ortalama 7-15 iş günü. Acil projeleriniz için ekspres üretim seçeneğimiz mevcut.</p>
            </div>
            <div class="glass-card p-5">
              <div class="text-primary text-2xl mb-2">🛡️</div>
              <h3 class="font-bold text-white mb-2">2 Yıl Garanti</h3>
              <p class="text-gray-400 text-sm">Tüm tabela projelerimizde 2 yıl malzeme ve işçilik garantisi. Montaj sonrası destek hattımız 7/24 aktif.</p>
            </div>
          </div>
        </section>

        <!-- Süreç Nasıl İşliyor? -->
        <section class="mb-12">
          <h2 class="font-heading text-2xl font-bold text-white mb-6">
            Süreç Nasıl İşliyor?
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="text-center">
              <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center">
                <span class="text-primary font-heading font-bold text-lg">1</span>
              </div>
              <h3 class="font-bold text-white text-sm mb-1">Keşif</h3>
              <p class="text-gray-400 text-xs">{district.name}'ye ekip gönderiyoruz, yerinde ölçüm alıyoruz</p>
            </div>
            <div class="text-center">
              <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center">
                <span class="text-primary font-heading font-bold text-lg">2</span>
              </div>
              <h3 class="font-bold text-white text-sm mb-1">Tasarım</h3>
              <p class="text-gray-400 text-xs">3D görselleştirme ve malzeme seçimi yapıyoruz</p>
            </div>
            <div class="text-center">
              <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center">
                <span class="text-primary font-heading font-bold text-lg">3</span>
              </div>
              <h3 class="font-bold text-white text-sm mb-1">Üretim</h3>
              <p class="text-gray-400 text-xs">Kendi atölyemizde profesyonel üretim gerçekleştiriyoruz</p>
            </div>
            <div class="text-center">
              <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center">
                <span class="text-primary font-heading font-bold text-lg">4</span>
              </div>
              <h3 class="font-bold text-white text-sm mb-1">Montaj</h3>
              <p class="text-gray-400 text-xs">Uzman ekibimiz ile güvenli montaj ve teslim</p>
            </div>
          </div>
        </section>

        <!-- KURUMSAL CROSS-SELL -->
        <section class="mb-12">
          <a href="/kurumsal-tabela/" class="block group">
            <div class="p-6 md:p-8 bg-gradient-to-br from-primary/15 via-secondary/50 to-primary/5 border-2 border-primary/40 rounded-2xl hover:border-primary transition-all">
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between">
                <div class="flex-1">
                  <div class="inline-flex items-center gap-2 mb-2 text-primary text-xs font-semibold uppercase tracking-wider">
                    <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
                    {district.name} • Kurumsal Projeler
                  </div>
                  <h3 class="font-heading font-bold text-xl md:text-2xl text-white mb-2 !mt-0">
                    {district.name}'de AVM, Plaza, Otel Tabelası Yapılır Mı?
                  </h3>
                  <p class="text-gray-300 text-sm md:text-base leading-relaxed">
                    Evet — {district.name} dahil İstanbul'un 39 ilçesinde kurumsal ölçek projeler için
                    <strong class="text-white">ücretsiz keşif + 3D tasarım + aynı gün teklif</strong>.
                  </p>
                </div>
                <span class="flex-shrink-0 inline-flex items-center gap-2 bg-primary text-secondary font-bold py-3 px-6 rounded-lg group-hover:bg-white transition-all text-sm md:text-base whitespace-nowrap">
                  Kurumsal Çözümler
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </section>

        <!-- Telefon CTA Band -->
        <CallBand context={`${district.name} tabela`} />

        <!-- SSS -->
        <section class="mb-12">
          <h2 class="font-heading text-2xl font-bold text-white mb-6">
            Sıkça Sorulan Sorular
          </h2>
          <div class="space-y-4">
            {district.content.faq.map((item: { question: string; answer: string }) => (
              <details class="glass-card p-5 group">
                <summary class="font-bold text-white cursor-pointer list-none flex justify-between items-center">
                  {item.question}
                  <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <p class="text-gray-300 mt-3 leading-relaxed">{item.answer}</p>
              </details>
            ))}
          </div>
        </section>

        <!-- Google Map Embed -->
        <section class="mb-12">
          <h2 class="font-heading text-2xl font-bold text-white mb-4">
            {district.name} Konum
          </h2>
          <div class="rounded-xl overflow-hidden border border-white/10">
            <iframe
              src={`https://maps.google.com/maps?q=tabelac%C4%B1+${encodeURIComponent(district.name)}+istanbul&t=&z=13&ie=UTF8&iwloc=&output=embed`}
              width="100%"
              height="350"
              style="border:0;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`${district.name} tabela hizmet bölgesi haritası`}
            />
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <!-- CTA -->
          <div class="bg-accent-light p-6 rounded-xl border border-white/5 shadow-2xl text-center">
            <h3 class="font-heading font-bold text-lg mb-3 text-white uppercase tracking-tight">
              {district.name}'de <span class="text-primary">Tabela</span> Yaptırın
            </h3>
            <p class="text-gray-400 mb-4 text-sm leading-relaxed">
              Ücretsiz keşif ve fiyat teklifi alın
            </p>
            <!-- Güven Sinyalleri -->
            <div class="flex justify-center gap-3 mb-4 text-xs text-gray-400">
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                5.0
              </span>
              <span>2500+ Proje</span>
              <span>20+ Yıl</span>
            </div>
            <a href="/iletisim/" class="block w-full text-center bg-primary text-secondary font-black py-3 rounded-lg hover:bg-white transition-all uppercase tracking-widest text-sm mb-3">
              Teklif İste
            </a>
            <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full text-center bg-green-600 text-white font-bold py-3 rounded-lg hover:bg-green-500 transition-all text-sm">
              <img src="/assets/icons/social/whatsapp-white.svg" alt="" width="20" height="20" class="w-5 h-5" loading="lazy" decoding="async" aria-hidden="true" />
              WhatsApp
            </a>
            <a href={`tel:${PHONE_TEL}`} class="block mt-3 text-primary font-bold text-lg hover:text-white transition-colors">
              0531 618 16 72
            </a>
          </div>

          <!-- Diğer İlçeler -->
          <div class="glass-card p-5">
            <h3 class="font-heading font-bold text-base text-white mb-3">Diğer Hizmet Bölgeleri</h3>
            <div class="space-y-2">
              {nearbyDistricts.map((d) => (
                <a href={`/${d.slug}/`} class="block text-sm text-gray-400 hover:text-primary transition-colors py-1">
                  &rarr; {d.name} Tabelacı
                </a>
              ))}
            </div>
            <a href="/istanbul-tabelaci/" class="block mt-3 text-primary text-sm font-bold hover:text-white transition-colors">
              Tüm Bölgeleri Gör &rarr;
            </a>
          </div>

          <!-- Hizmetler -->
          <div class="glass-card p-5">
            <h3 class="font-heading font-bold text-base text-white mb-3">Hizmetlerimiz</h3>
            <div class="space-y-2">
              {serviceLinks.map(service => (
                <a href={service.href} class="block text-sm text-gray-400 hover:text-primary transition-colors py-1">
                  &rarr; {service.title}
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </div>

    <!-- B3: Tüm İlçe Linkleri (Internal Linking Boost) -->
    <section class="py-12 border-t border-white/10 mt-8">
      <h2 class="font-heading text-xl font-bold text-white mb-4 text-center">
        İstanbul'da Tabela Hizmet Bölgelerimiz
      </h2>
      <div class="flex flex-wrap justify-center gap-2">
        {allOtherDistricts.map(d => (
          <a href={`/${d.slug}/`}
             class="text-xs text-gray-400 hover:text-primary transition-colors px-2 py-1">
            {d.name} Tabelacı
          </a>
        ))}
      </div>
      <div class="text-center mt-4">
        <a href="/istanbul-tabelaci/" class="text-primary text-sm font-bold hover:text-white transition-colors">
          Tüm Hizmet Bölgeleri &rarr;
        </a>
      </div>
    </section>

  </main>
</Layout>
