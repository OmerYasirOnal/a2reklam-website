---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/landing/Hero.astro';
import ServicesGrid from '../components/landing/ServicesGrid.astro';
import KPISection from '../components/landing/KPISection.astro';
import ReviewsSection from '../components/landing/ReviewsSection.astro';
import GallerySlider from '../components/landing/GallerySlider.astro';
import VideoProjectsSection from '../components/landing/VideoProjectsSection.astro';
import ClientLogos from '../components/common/ClientLogos.astro';
import TabelaRehberiPreview from '../components/landing/TabelaRehberiPreview.astro';
import FAQ from '../components/seo/FAQ.astro';
import ScrollReveal from '../components/common/ScrollReveal.astro';
import { districts } from '../data/districts';
import { sectors } from '../data/sectors';

const topDistricts = districts.filter(d => d.priority === 1);
const topSectors = sectors.slice(0, 10);
---

<Layout
  title="A2 Reklam | İstanbul Tabela İmalatı ve Reklam Çözümleri"
  description="İstanbul'da profesyonel tabela imalatı: ışıklı tabela, kutu harf, cephe tabelası, totem tabela ve araç giydirme. 2005'ten beri 2.500+ proje. Ücretsiz keşif ve teklif alın."
>
	<Hero lang="tr" />
  <ScrollReveal><ServicesGrid lang="tr" /></ScrollReveal>
  <ScrollReveal delay={100}><KPISection lang="tr" /></ScrollReveal>
  <ScrollReveal delay={150}><ReviewsSection lang="tr" /></ScrollReveal>
  <ScrollReveal><TabelaRehberiPreview lang="tr" /></ScrollReveal>
  <ScrollReveal><GallerySlider lang="tr" /></ScrollReveal>
  <ScrollReveal><VideoProjectsSection lang="tr" /></ScrollReveal>

  <!-- KURUMSAL CTA BAND -->
  <ScrollReveal>
  <section class="py-20 bg-gradient-to-br from-primary/10 via-secondary to-primary/5 border-t border-white/5 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(201,162,39,0.15),transparent_50%)]"></div>

    <div class="relative max-w-6xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 mb-5 px-4 py-2 bg-primary/10 border border-primary/30 rounded-full">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        <span class="text-primary text-sm font-semibold uppercase tracking-wider">AVM • Plaza • Fabrika • Hastane • Otel</span>
      </div>

      <h2 class="text-4xl md:text-5xl font-heading font-bold text-white mb-6 uppercase tracking-tight">
        Kurumsal Tabela <span class="text-primary">Projeniz Mi Var?</span>
      </h2>
      <p class="text-xl text-gray-400 mb-8 max-w-3xl mx-auto leading-relaxed">
        2.500+ kurumsal projede 20 yılı aşkın deneyim. AVM, plaza, hastane, otel için
        <strong class="text-white">ücretsiz keşif, 3D tasarım, aynı gün teklif</strong>.
      </p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10 max-w-4xl mx-auto">
        <div class="p-4 bg-secondary/60 rounded-xl border border-white/5">
          <div class="text-3xl mb-1">🛍</div>
          <div class="text-white font-bold text-sm">AVM</div>
        </div>
        <div class="p-4 bg-secondary/60 rounded-xl border border-white/5">
          <div class="text-3xl mb-1">🏢</div>
          <div class="text-white font-bold text-sm">Plaza</div>
        </div>
        <div class="p-4 bg-secondary/60 rounded-xl border border-white/5">
          <div class="text-3xl mb-1">🏥</div>
          <div class="text-white font-bold text-sm">Hastane</div>
        </div>
        <div class="p-4 bg-secondary/60 rounded-xl border border-white/5">
          <div class="text-3xl mb-1">🏨</div>
          <div class="text-white font-bold text-sm">Otel</div>
        </div>
      </div>

      <a
        href="/kurumsal-tabela/"
        class="inline-flex items-center justify-center gap-3 bg-primary text-secondary font-bold py-5 px-10 rounded-xl text-lg hover:bg-white transition-all transform hover:-translate-y-1 shadow-2xl shadow-primary/30"
        data-track="kurumsal_cta_click"
      >
        Kurumsal Çözümleri İncele
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
  </ScrollReveal>

  <!-- Trust/Stats Section -->
  <ScrollReveal>
  <section class="py-20 bg-secondary border-t border-white/5 relative">
    <div class="container mx-auto px-4 text-center relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 reveal-stagger">
        <div class="p-4 md:p-6 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/5 hover:border-primary/50 transition-all group">
          <span class="block text-xl sm:text-2xl md:text-4xl font-heading font-bold text-primary mb-1 md:mb-2 group-hover:scale-105 transition-transform duration-300">Kurumsal</span>
          <span class="text-gray-400 text-[11px] sm:text-xs md:text-sm font-medium uppercase tracking-wider group-hover:text-white transition-colors">B2B Odaklı Üretim</span>
        </div>
        <div class="p-4 md:p-6 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/5 hover:border-primary/50 transition-all group">
          <span class="block text-xl sm:text-2xl md:text-4xl font-heading font-bold text-primary mb-1 md:mb-2 group-hover:scale-105 transition-transform duration-300">Uçtan Uca</span>
          <span class="text-gray-400 text-[11px] sm:text-xs md:text-sm font-medium uppercase tracking-wider group-hover:text-white transition-colors">Keşiften Montaja</span>
        </div>
        <div class="p-4 md:p-6 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/5 hover:border-primary/50 transition-all group">
          <span class="block text-xl sm:text-2xl md:text-4xl font-heading font-bold text-primary mb-1 md:mb-2 group-hover:scale-105 transition-transform duration-300">İstanbul</span>
          <span class="text-gray-400 text-[11px] sm:text-xs md:text-sm font-medium uppercase tracking-wider group-hover:text-white transition-colors">39 İlçeye Hizmet</span>
        </div>
        <div class="p-4 md:p-6 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/5 hover:border-primary/50 transition-all group">
          <span class="block text-xl sm:text-2xl md:text-4xl font-heading font-bold text-primary mb-1 md:mb-2 group-hover:scale-105 transition-transform duration-300">Kalite</span>
          <span class="text-gray-400 text-[11px] sm:text-xs md:text-sm font-medium uppercase tracking-wider group-hover:text-white transition-colors">Premium Malzeme</span>
        </div>
      </div>
    </div>
  </section>
  </ScrollReveal>

  <!-- Hizmet Bölgeleri Section -->
  <ScrollReveal>
  <section class="py-16 bg-secondary border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-white text-center mb-4 uppercase tracking-tight">
        İstanbul'un Her İlçesine <span class="text-primary">Tabela Hizmeti</span>
      </h2>
      <p class="text-gray-400 text-center mb-10 max-w-2xl mx-auto">
        Kağıthane merkezimizden İstanbul'un 39 ilçesine profesyonel tabela imalatı ve montaj hizmeti sunuyoruz.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        {topDistricts.map(d => (
          <a href={`/${d.slug}/`} class="group p-4 glass-card hover:border-primary/50 transition-all text-center">
            <span class="block text-sm font-bold text-gray-300 group-hover:text-primary transition-colors">{d.name}</span>
            <span class="text-xs text-gray-500 mt-1 block">Tabelacı</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/istanbul-tabelaci/" class="text-primary font-bold hover:text-white transition-colors">
          Tüm İlçeleri Gör &rarr;
        </a>
      </div>
    </div>
  </section>
  </ScrollReveal>

  <!-- Sektörel Tabela Çözümleri -->
  <ScrollReveal>
  <section class="py-16 bg-secondary border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-white text-center mb-4 uppercase tracking-tight">
        Her Sektöre Özel <span class="text-primary">Tabela Çözümü</span>
      </h2>
      <p class="text-gray-400 text-center mb-10 max-w-2xl mx-auto">
        Berberden eczaneye, cafeden fabrikaya — sektörünüze özel tasarım ve üretim.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        {topSectors.map(s => (
          <a href={`/sektorel/${s.slug}/`} class="group p-4 glass-card hover:border-primary/50 transition-all text-center">
            <span class="text-2xl block mb-1">{s.icon}</span>
            <span class="block text-xs font-bold text-gray-300 group-hover:text-primary transition-colors">{s.name}</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/sektorel/" class="text-primary font-bold hover:text-white transition-colors">
          Tüm Sektörleri Gör &rarr;
        </a>
      </div>
    </div>
  </section>
  </ScrollReveal>

  <!-- Client Logos Section -->
  <ClientLogos lang="tr" />

  <!-- SEO Content Section (AIO/Google-visible text) -->
  <section class="py-16 bg-secondary border-t border-white/5">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading font-bold text-2xl md:text-3xl text-white mb-6 text-center uppercase tracking-tight">
          İstanbul'da <span class="text-primary">Profesyonel Tabela</span> İmalatı
        </h2>
        <div class="prose prose-invert prose-sm md:prose-base max-w-none text-gray-400 leading-relaxed space-y-4">
          <p>
            <strong class="text-white">A2 Reklam</strong>, İstanbul Kağıthane merkezli atölyesinden 39 ilçeye profesyonel <strong class="text-white">tabela imalatı</strong> ve kurumsal reklam çözümleri sunmaktadır. 20 yılı aşkın sektör deneyimimizle <strong class="text-white">ışıklı tabela</strong>, <strong class="text-white">ışıksız tabela</strong>, <strong class="text-white">paslanmaz harf</strong>, <strong class="text-white">cephe tabelası</strong>, <strong class="text-white">çatı tabelası</strong> ve <strong class="text-white">totem tabela</strong> başta olmak üzere geniş bir ürün yelpazesinde hizmet vermekteyiz.
          </p>
          <p>
            CNC lazer kesim, LED aydınlatma sistemleri ve PVD kaplama teknolojileri ile ürettiğimiz <strong class="text-white">gold harf</strong>, <strong class="text-white">gümüş harf</strong> ve <strong class="text-white">kurumsal tabela</strong> çözümlerimiz; Maslak, Levent, Etiler, Beşiktaş, Sarıyer ve Kağıthane başta olmak üzere İstanbul'un tüm iş merkezleri ve ticari bölgelerinde hizmetinizdedir.
          </p>
          <p>
            <strong class="text-white">Kumlama folyo</strong>, <strong class="text-white">araç giydirme</strong>, ofis yönlendirme ve <strong class="text-white">AVM tabelası</strong> konularında da uzman ekibimizle keşiften montaja kadar uçtan uca hizmet sunuyoruz. Ücretsiz keşif ve 3D tasarım hizmetimizden yararlanmak için <a href="/iletisim/" class="text-primary hover:text-white transition-colors underline underline-offset-2">bizimle iletişime</a> geçin.
          </p>
          <p>
            Her sektörün tabela ihtiyacı farklıdır. <a href="/sektorel/berber-tabelasi/" class="text-primary hover:text-white transition-colors underline underline-offset-2">Berber tabelası</a>, <a href="/sektorel/eczane-tabelasi/" class="text-primary hover:text-white transition-colors underline underline-offset-2">eczane tabelası</a>, <a href="/sektorel/cafe-restoran-tabelasi/" class="text-primary hover:text-white transition-colors underline underline-offset-2">cafe ve restoran tabelası</a>, <a href="/sektorel/otel-tabelasi/" class="text-primary hover:text-white transition-colors underline underline-offset-2">otel tabelası</a> ve <a href="/sektorel/fabrika-tabelasi/" class="text-primary hover:text-white transition-colors underline underline-offset-2">fabrika tabelası</a> gibi <a href="/sektorel/" class="text-primary hover:text-white transition-colors underline underline-offset-2">20 farklı sektöre özel</a> tabela çözümleri sunuyoruz. <a href="/istanbul-tabelaci/" class="text-primary hover:text-white transition-colors underline underline-offset-2">İstanbul'un 39 ilçesine</a> hizmet veren ekibimiz, her projeyi tasarımdan montaja kadar profesyonelce yönetmektedir.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sık Sorulan Sorular -->
  <FAQ />

</Layout>
