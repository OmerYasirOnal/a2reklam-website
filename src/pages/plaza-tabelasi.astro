---
import Layout from '../layouts/Layout.astro';
import CallBand from '../components/common/CallBand.astro';
import { PHONE_NUMBER, GOOGLE_RATING, GOOGLE_REVIEW_COUNT } from '../consts';

const breadcrumbs = [
  { name: 'Anasayfa', item: '/' },
  { name: 'Kurumsal Tabela', item: '/kurumsal-tabela/' },
  { name: 'Plaza Tabela', item: '/plaza-tabelasi/' },
];

const faq = [
  {
    question: 'Plaza tabelasında hangi malzemeler önerilir?',
    answer: 'Plaza dış cephe tabelalarında paslanmaz çelik (304 kalite) + PVD kaplama + IP65 LED kombinasyonu ideal: 15+ yıl dayanım, uzun ömürlü parlaklık, düşük enerji. Lobi ve kat yönlendirme için fırın boyalı alüminyum veya kompozit panel yaygın.',
  },
  {
    question: 'Plaza giriş logosu boyutu ne olmalı?',
    answer: 'Standart plaza girişinde 80×80 cm ile 200×200 cm arası logo önerilir. Yükseklik+izleme mesafesi oranı 1:10 (10 metre mesafeden okunabilir). A2 Reklam keşif sırasında tam görünürlük analizi yapar.',
  },
  {
    question: 'Kat yönlendirme sistemi nasıl planlanır?',
    answer: 'Her plazada kat sayısı × ofis sayısı × firma logo alanı matrisine göre sistem kurgulanır. Standart: asansör lobisinde kat endeksi, her kat hollünde firma+oda no, acil çıkış yönlendirme. Modüler değiştirilebilir sistemler tercih edilir (kiracı değişiminde hızlı güncelleme).',
  },
  {
    question: 'Plaza tabelası için ne kadar süre gerekir?',
    answer: 'Standart plaza giriş + lobi paketi 15-25 iş günü. Komple plaza (dış cephe + lobi + kat yönlendirme + oda no) 30-45 iş gün. Aşamalı teslim: cephe logosu → lobi → kat yönlendirme → oda no.',
  },
  {
    question: 'Plaza yönetimi ile koordinasyonu siz mi yapıyorsunuz?',
    answer: 'Evet. Plaza yöneticisi, mimar ofisi, kiracı firması arasındaki tüm teknik koordinasyonu biz yapıyoruz. Çalışma saatleri, yüksekte çalışma izinleri, montaj lokasyonları için bürokratik süreçleri takip ediyoruz.',
  },
  {
    question: 'Çoklu kiracılı plazalarda tabela yenileme yapar mısınız?',
    answer: 'Evet, kiracı değişikliklerinde 1-3 iş günü içinde kat yönlendirme paneli güncellenir. Modüler sistem kullandığımız için sadece ilgili modül değiştirilir, tüm sistem sökülmez.',
  },
  {
    question: 'Daha önce hangi plazalarda çalıştınız?',
    answer: 'Metrocity, Levent 199, Sabancı Center, Istanbloom, Maya Akar Center, Wyndham Levent, Palladium Ataşehir, Sun Plaza, Kapital Plaza, Şişli Plaza ve 50+ iş merkezi projesinde referans.',
  },
];

const plazaServices = [
  { icon: '🏢', title: 'Dış Cephe Logo', desc: 'Paslanmaz PVD kaplama harf + LED arka aydınlatma. Kurumsal kimlik uyumlu.' },
  { icon: '🪟', title: 'Lobi Tabelası', desc: 'Giriş resepsiyon tabelası, firma listesi, kat endeksi. Premium malzeme.' },
  { icon: '🔢', title: 'Kat Yönlendirme', desc: 'Asansör lobi + kat holü yönlendirme. Modüler, değiştirilebilir.' },
  { icon: '🚪', title: 'Oda & Ofis No', desc: 'Kapı no plakaları, ofis isimlik. Fırın boya veya pleksi.' },
  { icon: '🅿️', title: 'Otopark Yönlendirme', desc: 'Kat, yön, çıkış. Reflektörlü görünürlük, anti-korozyon.' },
  { icon: '⚠', title: 'Acil Çıkış + Güvenlik', desc: 'Foto-lüminesan, yangın yönetmeliğine uygun.' },
];

const process = [
  { n: 1, title: 'Proje Brief + Kimlik Analizi', desc: 'Plaza CI/CD dokümanı, kiracı rehberi, mimar çizimleri incelenir.' },
  { n: 2, title: 'Keşif + 3D Render', desc: 'Saha ziyaretiyle ölçüm. Her tabela için fotoğraf-üstü 3D render sunulur.' },
  { n: 3, title: 'Malzeme Mockup', desc: 'Paslanmaz/PVD/LED fiziksel örnek. Renk + aydınlatma testi plazada yapılır.' },
  { n: 4, title: 'Üretim (15-30 gün)', desc: 'CNC lazer kesim + PVD + LED montaj. Her parça QC\'den geçer.' },
  { n: 5, title: 'Mesai Dışı Montaj', desc: 'Plaza operasyonunu aksatmadan hafta sonu veya gece.' },
  { n: 6, title: 'Teslim + Bakım Planı', desc: '2 yıl garanti + yıllık periyodik bakım anlaşması opsiyonu.' },
];

const title = 'Plaza Tabela İmalatı İstanbul | Dış Cephe, Lobi, Kat Yönlendirme | A2 Reklam';
const description = "İstanbul'da plaza tabela imalatı: dış cephe logo, lobi, kat yönlendirme. ⭐5.0/90 yorum, 50+ plaza projesi. Paslanmaz + PVD + LED. ☎ 0531 618 16 72";
---

<Layout
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
  faq={faq}
  whatsappTitle="Plaza Tabela"
>
  <section class="relative bg-secondary min-h-[60vh] flex items-center py-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/10"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 mb-4 text-primary text-sm font-semibold uppercase tracking-wider">
          <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
          Dış cephe • Lobi • Kat yönlendirme • Otopark
        </div>
        <h1 class="font-heading font-bold text-4xl md:text-6xl text-white uppercase tracking-tight mb-4">
          PLAZA TABELA <span class="text-primary">İMALATI</span>
        </h1>
        <p class="text-gray-300 max-w-2xl mx-auto text-lg leading-relaxed">
          İstanbul'un önde gelen plazalarında <strong class="text-white">50+ komple proje</strong>.
          Paslanmaz PVD + IP65 LED. <strong class="text-primary">⭐{GOOGLE_RATING}/{GOOGLE_REVIEW_COUNT} yorum</strong>.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`tel:${PHONE_NUMBER.replace(/\s/g, '')}`} data-track="call" class="bg-primary text-secondary font-bold px-8 py-4 rounded-xl hover:bg-white transition-all">☎ {PHONE_NUMBER}</a>
          <a href="/iletisim/" data-track="quote" class="bg-white/10 border-2 border-primary/40 text-white font-bold px-8 py-4 rounded-xl hover:border-primary hover:bg-primary/10 transition-all">Ücretsiz Keşif Al</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-secondary">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-12 uppercase">
        Plaza'da <span class="text-primary">Tabela Türleri</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {plazaServices.map(t => (
          <div class="p-6 glass-card hover:border-primary/50 transition-all">
            <div class="text-4xl mb-3">{t.icon}</div>
            <h3 class="font-heading font-bold text-xl text-white mb-2">{t.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-secondary/80">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-12 uppercase">
        Plaza Tabela <span class="text-primary">Süreci</span>
      </h2>
      <div class="space-y-4">
        {process.map(s => (
          <div class="flex gap-4 p-6 glass-card hover:border-primary/50 transition-all">
            <div class="flex-shrink-0 w-12 h-12 bg-primary text-secondary rounded-full flex items-center justify-center font-bold text-xl">{s.n}</div>
            <div>
              <h3 class="font-heading font-bold text-xl text-white mb-1">{s.title}</h3>
              <p class="text-gray-400 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-primary/10 via-secondary to-secondary">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-5xl md:text-6xl font-heading font-bold text-primary mb-4">50+</div>
      <p class="text-xl text-white font-semibold mb-2">İstanbul Plaza Projesi</p>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Metrocity, Levent 199, Sabancı Center, Istanbloom, Maya Akar Center, Wyndham Levent,
        Palladium Ataşehir, Sun Plaza, Kapital Plaza, Şişli Plaza — İstanbul'un saygın plazalarında 20+ yıl deneyim.
      </p>
    </div>
  </section>

  <section class="py-16 bg-secondary">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-10 uppercase">
        Sıkça Sorulan <span class="text-primary">Sorular</span>
      </h2>
      <div class="space-y-4">
        {faq.map(item => (
          <details class="p-6 glass-card group">
            <summary class="font-heading font-bold text-white cursor-pointer list-none flex justify-between items-center">
              <span>{item.question}</span>
              <span class="text-primary text-2xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-gray-400 mt-4 leading-relaxed">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CallBand />
</Layout>
