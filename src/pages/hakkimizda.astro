---
import Layout from '../layouts/Layout.astro';

const title = "Hakkımızda | A2 Reklam";
const description = "2005'ten beri İstanbul'da 2.500+ tabela projesi tamamlayan A2 Reklam. CNC lazer kesim, LED aydınlatma ve PVD kaplama uzmanı. 5.0 Google puan, 87 müşteri değerlendirmesi.";
---

<Layout title={title} description={description} lang="tr">
  <div class="relative py-24 bg-secondary overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="container mx-auto px-4 relative z-10">
      <div class="text-center mb-20">
        <h1 class="font-heading font-bold text-4xl md:text-6xl mb-6 text-white uppercase tracking-tight">
          BİZ <span class="text-primary">KİMİZ?</span>
        </h1>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg border-l-2 border-primary pl-4 inline-block">
          A2 Reklam, kurumsal tabela ve reklam projelerinde markaların görünürlüğünü artıracak üretim ve uygulama çözümleri sunar.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-24">
        <div class="relative">
          <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-primary opacity-50"></div>
          <div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-primary opacity-50"></div>
          <img src="/assets/img/demo/a2reklam-cephe-tabela-001-1600.webp" alt="A2 Reklam Atölye" class="rounded-2xl shadow-2xl grayscale hover:grayscale-0 transition-all duration-700" />
        </div>
        <div class="space-y-6">
          <h2 class="font-heading font-bold text-3xl text-white">Tecrübemiz, Markanızın <span class="text-primary">Gücüdür.</span></h2>
          <p class="text-gray-400 leading-relaxed">
            İstanbul merkezli ekibimiz, keşif, tasarım, üretim ve montaj adımlarını tek plan altında yürütür. Proje ihtiyaçlarına göre malzeme ve uygulama seçeneklerini netleştirerek kurumsal kimliğe uygun çözümler geliştiririz.
          </p>
          <p class="text-gray-400 leading-relaxed">
            Fabrika, otel, mağaza ve ofis projelerinde teknik detayları önceden planlayarak uygulama sürecini şeffaf şekilde yönetiriz. Tabela üretimini, markanın sahadaki görünürlüğünü güçlendiren stratejik bir yatırım olarak ele alırız.
          </p>
          <div class="grid grid-cols-2 gap-6 pt-6">
            <div class="border-l-2 border-primary pl-4">
              <span class="block text-white font-black text-2xl">VİZYON</span>
              <p class="text-xs text-gray-500 uppercase tracking-widest mt-1 leading-relaxed">Sektörde global standartlarda üretim yapan, teknoloji ile tasarımı birleştiren öncü marka olmak.</p>
            </div>
            <div class="border-l-2 border-primary pl-4">
              <span class="block text-white font-black text-2xl">MİSYON</span>
              <p class="text-xs text-gray-500 uppercase tracking-widest mt-1 leading-relaxed">Müşterilerimizin kurumsal kimliğini en doğru ve en etkileyici şekilde yansıtacak çözümler üretmek.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Values Section -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
        {[
          { title: 'KALİTELİ ÜRETİM', desc: 'Projeye uygun malzeme ve üretim teknikleriyle uzun ömürlü çözümler hedefleriz.' },
          { title: 'PLANLI TESLİMAT', desc: 'Keşif sonrası net bir üretim ve montaj planı oluşturarak süreci şeffaf yönetiriz.' },
          { title: 'ÜRETİCİ DESTEĞİ', desc: 'Malzeme ve uygulama süreçlerinde proje bazlı destek ve bakım seçenekleri sunarız.' }
        ].map(item => (
          <div class="p-8 bg-accent-light rounded-2xl border border-white/5 hover:border-primary/30 transition-all">
            <h3 class="text-white font-bold text-xl mb-3 tracking-tight group-hover:text-primary">{item.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Rakamlarla A2 Reklam -->
      <div class="mb-24">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-12 uppercase tracking-tight">
          Rakamlarla <span class="text-primary">A2 Reklam</span>
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
          {[
            { value: '2005\'ten Beri', label: 'Sektörde 20+ yıl' },
            { value: '2.500+', label: 'Tamamlanan proje' },
            { value: '39 İlçe', label: 'İstanbul geneli hizmet' },
            { value: '87', label: 'Google yorum (5.0 puan)' },
            { value: '400 m²', label: 'Üretim atölyesi' },
            { value: '1.200+', label: 'Mutlu müşteri' },
          ].map(stat => (
            <div class="p-6 bg-accent-light rounded-2xl border border-white/10 text-center hover:border-primary/30 transition-all">
              <span class="block text-2xl md:text-3xl font-heading font-black text-primary mb-2">{stat.value}</span>
              <span class="block text-gray-400 text-sm">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Uzmanlık Alanlarımız -->
      <div class="mb-24">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-4 uppercase tracking-tight">
          Uzmanlık <span class="text-primary">Alanlarımız</span>
        </h2>
        <p class="text-gray-400 text-center max-w-2xl mx-auto mb-12">
          Tabela üretim sürecinin her aşamasında kullandığımız teknik yetkinlikler ve ekipmanlar.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            { title: 'CNC Lazer Kesim', desc: 'Hassas metal ve akrilik kesim işlemleriyle milimetrik doğrulukta harf ve logo üretimi.' },
            { title: 'LED Aydınlatma Sistemleri', desc: 'Enerji verimli LED modül ve neon flex uygulamalarıyla uzun ömürlü aydınlatma çözümleri.' },
            { title: 'Elektrostatik Toz Boya', desc: 'Dış mekan koşullarına dayanıklı, solmayan ve çizilmeye karşı dirençli yüzey kaplaması.' },
            { title: 'PVD Kaplama', desc: 'Gold, rose gold, siyah krom gibi premium metal kaplamalarla kurumsal görünüm.' },
            { title: 'Dijital Baskı', desc: 'UV baskı ve folyo uygulamalarıyla yüksek çözünürlüklü, dayanıklı görseller.' },
            { title: '3D Tasarım', desc: 'Montaj öncesi profesyonel görselleştirme ile projenizi canlı olarak önizleyin.' },
          ].map(item => (
            <div class="p-8 bg-accent-light rounded-2xl border border-white/10 hover:border-primary/30 transition-all">
              <h3 class="text-white font-bold text-xl mb-3 tracking-tight">{item.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Kalite Standartlarımız -->
      <div class="mb-24">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-4 uppercase tracking-tight">
          Kalite <span class="text-primary">Standartlarımız</span>
        </h2>
        <p class="text-gray-400 text-center max-w-2xl mx-auto mb-12">
          Her projede uygulanan kalite taahhütlerimiz ve müşteri güvenceleri.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            { title: 'UV Dayanımlı Malzemeler', desc: 'Dış mekan uygulamalarında güneş ışığına karşı dayanıklı, solmayan malzemeler kullanırız.' },
            { title: 'LED Modül Garantisi', desc: 'Kullandığımız LED modüllerde 5 yıl üretici garantisi sağlarız.' },
            { title: 'İşçilik Garantisi', desc: 'Tüm montaj ve üretim işçiliğinde 2 yıl garanti veriyoruz.' },
            { title: 'Ruhsat Danışmanlığı', desc: 'Belediye tabela ruhsat sürecinde başvurudan onaya kadar danışmanlık desteği.' },
            { title: 'Ücretsiz Keşif', desc: 'İstanbul genelinde ücretsiz keşif ve profesyonel ölçü hizmeti sunuyoruz.' },
            { title: 'Proje Sigortası', desc: 'Büyük ölçekli projelerde proje bazlı sigorta kapsamı ile güvence sağlıyoruz.' },
          ].map(item => (
            <div class="p-6 bg-accent-light rounded-2xl border border-white/10 hover:border-primary/30 transition-all">
              <div class="flex items-start gap-3">
                <span class="text-primary text-xl mt-0.5 shrink-0">&#10003;</span>
                <div>
                  <h3 class="text-white font-bold text-lg mb-1">{item.title}</h3>
                  <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Firma Tarihçesi -->
      <div class="mb-12">
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white text-center mb-4 uppercase tracking-tight">
          Firma <span class="text-primary">Tarihçesi</span>
        </h2>
        <p class="text-gray-400 text-center max-w-2xl mx-auto mb-12">
          2005'ten bugüne A2 Reklam'ın büyüme yolculuğu.
        </p>
        <div class="max-w-3xl mx-auto relative">
          <!-- Timeline line -->
          <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-white/10 md:-translate-x-0.5"></div>

          {[
            { year: '2005', text: 'Tabela sektörüne ilk adım atıldı, küçük ölçekli projelerle yola çıkıldı.' },
            { year: '2010', text: 'Kağıthane\'de kendi üretim atölyesine geçiş yapıldı.' },
            { year: '2015', text: 'CNC lazer kesim makinesi yatırımı ile hassas üretim kapasitesine ulaşıldı.' },
            { year: '2018', text: 'LED aydınlatma sistemlerine tam geçiş sağlandı.' },
            { year: '2020', text: 'Dijital baskı ve araç giydirme üretim hattı devreye alındı.' },
            { year: '2023', text: '2.000. proje teslimi gerçekleştirildi.' },
            { year: '2025', text: '400 m² üretim tesisi ile İstanbul\'un 39 ilçesine hizmet veriliyor.' },
          ].map((item, index) => (
            <div class:list={['relative flex items-start mb-10 last:mb-0', index % 2 === 0 ? 'md:flex-row-reverse' : '']}>
              {/* Dot */}
              <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-primary rounded-full -translate-x-1.5 mt-1.5 z-10 md:-translate-x-1.5"></div>

              {/* Content */}
              <div class:list={['ml-12 md:ml-0 md:w-1/2', index % 2 === 0 ? 'md:pl-10' : 'md:pr-10 md:text-right']}>
                <span class="inline-block text-primary font-heading font-black text-xl mb-1">{item.year}</span>
                <p class="text-gray-400 text-sm leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
