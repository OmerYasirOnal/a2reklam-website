---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Sayfa Bulunamadı - A2 Reklam"
  description="Aradığınız sayfa bulunamadı. İstanbul tabela imalatı, hizmetlerimiz ve iletişim bilgilerimiz için ana sayfamızı ziyaret edin."
  lang="tr"
  noindex={true}
>
  <div class="py-24 bg-secondary">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h1 class="text-[10rem] md:text-[12rem] font-heading font-extrabold text-white/5 leading-none select-none">404</h1>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-white -mt-16 mb-4">Sayfa Bulunamadı</h2>
        <p class="text-gray-400 max-w-md mx-auto mb-10">
          Aradığınız sayfa silinmiş, adı değiştirilmiş veya geçici olarak kullanım dışı olabilir.
        </p>
        <a href="/" class="inline-block bg-primary text-secondary font-black py-4 px-10 rounded-lg hover:bg-white transition-all transform hover:-translate-y-1 shadow-lg shadow-primary/20 uppercase tracking-widest text-sm mb-12">
          Anasayfaya Dön
        </a>

        <div class="mt-8 pt-8 border-t border-white/10">
          <p class="text-gray-500 text-sm mb-6 uppercase tracking-widest font-bold">Bunlar işinize yarayabilir</p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a href="/hizmetler/" class="p-4 rounded-xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all text-gray-400 hover:text-white text-sm font-medium">
              Hizmetler
            </a>
            <a href="/galeri/" class="p-4 rounded-xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all text-gray-400 hover:text-white text-sm font-medium">
              Galeri
            </a>
            <a href="/blog/" class="p-4 rounded-xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all text-gray-400 hover:text-white text-sm font-medium">
              Blog
            </a>
            <a href="/iletisim/" class="p-4 rounded-xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all text-gray-400 hover:text-white text-sm font-medium">
              İletişim
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
