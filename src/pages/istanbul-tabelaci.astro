---
import Layout from '../layouts/Layout.astro';
import { districts } from '../data/districts';
import { PHONE_TEL } from '../consts';

const priority1 = districts.filter(d => d.priority === 1);
const priority2 = districts.filter(d => d.priority === 2);
const priority3 = districts.filter(d => d.priority === 3);

const breadcrumbs = [
  { name: 'Anasayfa', item: '/' },
  { name: 'Hizmet Bölgeleri', item: '/istanbul-tabelaci/' },
];

const faq = [
  {
    question: 'İstanbul\'un hangi ilçelerine tabela hizmeti veriyorsunuz?',
    answer: 'A2 Reklam olarak İstanbul\'un 39 ilçesinin tamamına tabela imalatı ve montaj hizmeti veriyoruz. Kağıthane merkezimizden tüm Avrupa ve Anadolu Yakası ilçelerine hızlı erişim sağlıyoruz.',
  },
  {
    question: 'İstanbul\'da tabela yaptırmak ne kadar?',
    answer: 'Tabela fiyatları türe, boyuta ve malzemeye göre değişir. Kutu harf tabela 15.000₺\'den, ışıklı tabela 8.000₺\'den, totem tabela 25.000₺\'den başlar. Ücretsiz keşif sonrası detaylı fiyat teklifi sunuyoruz.',
  },
  {
    question: 'Tabela imalatı ne kadar sürer?',
    answer: 'Tabela türüne ve boyutuna göre üretim süresi 3-10 iş günü arasında değişir. Montaj genellikle 1 gün içinde tamamlanır. Acil projeler için hızlandırılmış üretim seçeneğimiz mevcuttur.',
  },
  {
    question: 'Ücretsiz keşif hizmeti var mı?',
    answer: 'Evet, İstanbul\'un tüm ilçelerinde ücretsiz keşif hizmeti sunuyoruz. Keşif sonrası 3D tasarım önerisi ve detaylı fiyat teklifi hazırlıyoruz.',
  },
  {
    question: 'Belediye tabela izin sürecinde yardımcı oluyor musunuz?',
    answer: 'Evet, tüm ilçe belediyelerinin ilan ve reklam izin süreçlerinde müşterilerimize destek sağlıyoruz. Başvuru, takip ve onay aşamalarında sizin adınıza işlemleri yürütüyoruz.',
  },
];

const whatsappLink = 'https://wa.me/905316181672?text=Merhaba, İstanbul\'da tabela hizmeti almak istiyorum.';
---

<Layout
  title="İstanbul Tabelacı | A2 Reklam — 39 İlçeye Tabela Hizmeti"
  description="İstanbul'un 39 ilçesine profesyonel tabela imalatı ve montaj. Kutu harf, ışıklı tabela, totem, cephe giydirme. 20 yıllık tecrübe. ☎ 0531 618 16 72"
  breadcrumbs={breadcrumbs}
  faq={faq}
  whatsappTitle="İstanbul Tabelacı"
  whatsappLocation="İstanbul"
>

  <section class="py-16 md:py-20 bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Hero -->
      <div class="text-center mb-16">
        <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl text-white mb-6 uppercase tracking-tight">
          İstanbul <span class="text-primary">Tabelacı</span>
        </h1>
        <p class="text-gray-400 max-w-3xl mx-auto text-lg leading-relaxed">
          İstanbul'un 39 ilçesine profesyonel tabela imalatı ve montaj hizmeti. Kağıthane merkezimizden tüm İstanbul'a hizmet veriyoruz.
        </p>
      </div>

      <!-- İçerik -->
      <div class="max-w-4xl mx-auto mb-16">
        <div class="prose prose-invert prose-lg max-w-none text-gray-300 leading-relaxed space-y-4">
          <p>
            <strong class="text-white">A2 Reklam</strong>, İstanbul Kağıthane'deki merkez atölyesinden İstanbul'un 39 ilçesine profesyonel <strong class="text-white">tabela imalatı</strong> ve kurumsal reklam çözümleri sunmaktadır. 2005 yılından bu yana 2.500'den fazla projeyi başarıyla tamamlayan deneyimli ekibimizle, küçük işletmelerden büyük kurumsal firmalara kadar geniş bir müşteri yelpazesine hizmet veriyoruz.
          </p>
          <p>
            <strong class="text-white">Kutu harf tabela</strong>, <strong class="text-white">ışıklı tabela</strong>, <strong class="text-white">totem tabela</strong>, <strong class="text-white">cephe giydirme</strong>, <strong class="text-white">araç giydirme</strong> ve <strong class="text-white">dijital baskı</strong> alanlarında uzmanlaşmış ekibimiz, her projeyi tasarımdan üretime, montajdan bakıma kadar uçtan uca yönetmektedir.
          </p>
          <p>
            İstanbul'un her bölgesinin kendine özgü tabela ihtiyaçları vardır. Levent ve Maslak'taki iş kuleleri kurumsal plaza tabelaları gerektirirken, İstiklal Caddesi ve Karaköy'deki tarihi bölgeler Koruma Kurulu onaylı özel tasarımlar istemektedir. İkitelli ve Beylikdüzü OSB'deki fabrikalar büyük ölçekli sanayi tabelalarına, Bağdat Caddesi ve Nişantaşı'ndaki mağazalar ise estetik marka tabelalarına ihtiyaç duymaktadır.
          </p>
          <p>
            A2 Reklam olarak her ilçenin belediye düzenlemelerine hakim ekibimizle tabela izin süreçlerinde de müşterilerimize destek sağlıyoruz. CNC lazer kesim, LED aydınlatma, PVD kaplama ve dijital baskı teknolojileriyle ürettiğimiz tabelalar dayanıklılık ve estetik açıdan en yüksek standartları karşılamaktadır.
          </p>
          <p>
            Ücretsiz keşif hizmetimizden yararlanmak ve projeniz için detaylı fiyat teklifi almak için <a href="/iletisim/" class="text-primary hover:text-white transition-colors underline underline-offset-2">bizimle iletişime geçin</a> veya <strong class="text-white">0531 618 16 72</strong> numarasından bizi arayın.
          </p>
        </div>
      </div>

      <!-- Öncelik 1 İlçeler - Büyük Kartlar -->
      <div class="mb-12">
        <h2 class="font-heading font-bold text-3xl text-white mb-8 uppercase tracking-tight">
          Öncelikli <span class="text-primary">Hizmet Bölgeleri</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {priority1.map(d => (
            <a href={`/${d.slug}/`} class="group glass-card p-6 hover:border-primary/50 transition-all transform hover:-translate-y-1">
              <h3 class="font-heading font-bold text-xl text-white group-hover:text-primary transition-colors mb-2">
                {d.name} Tabelacı
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed mb-3">
                {d.content.serviceHighlight}
              </p>
              <span class="text-primary text-sm font-bold group-hover:text-white transition-colors">
                Detaylar &rarr;
              </span>
            </a>
          ))}
        </div>
      </div>

      <!-- Öncelik 2 İlçeler -->
      <div class="mb-12">
        <h2 class="font-heading font-bold text-2xl text-white mb-6 uppercase tracking-tight">
          Diğer <span class="text-primary">Hizmet Bölgeleri</span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          {priority2.map(d => (
            <a href={`/${d.slug}/`} class="group p-4 glass-card hover:border-primary/50 transition-all text-center">
              <span class="block text-sm font-bold text-gray-300 group-hover:text-primary transition-colors">{d.name}</span>
              <span class="text-xs text-gray-500 mt-1 block">Tabelacı</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Öncelik 3 İlçeler -->
      <div class="mb-16">
        <h2 class="font-heading font-bold text-xl text-white mb-4 uppercase tracking-tight">
          Tüm <span class="text-primary">İlçeler</span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2">
          {priority3.map(d => (
            <a href={`/${d.slug}/`} class="group p-3 rounded-lg border border-white/5 hover:border-primary/30 transition-all text-center">
              <span class="text-xs font-medium text-gray-400 group-hover:text-primary transition-colors">{d.name}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Hizmet Türleri -->
      <div class="mb-16">
        <h2 class="font-heading font-bold text-2xl text-white mb-6 uppercase tracking-tight">
          Tabela <span class="text-primary">Hizmetlerimiz</span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          {[
            { title: 'Kutu Harf', href: '/hizmetler/paslanmaz-harfler/' },
            { title: 'Işıklı Tabela', href: '/hizmetler/isikli-tabela/' },
            { title: 'Totem Tabela', href: '/hizmetler/totem/' },
            { title: 'Cephe Tabela', href: '/hizmetler/cephe-tabela/' },
            { title: 'Araç Giydirme', href: '/hizmetler/arac-giydirme/' },
            { title: 'Yönlendirme', href: '/hizmetler/yonlendirme/' },
          ].map(s => (
            <a href={s.href} class="glass-card p-4 text-center hover:border-primary/50 transition-all group">
              <span class="text-sm font-bold text-gray-300 group-hover:text-primary transition-colors">{s.title}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-accent-light border border-white/5 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="font-heading font-bold text-3xl text-white mb-4">
          İstanbul'da <span class="text-primary">Tabela</span> Yaptırın
        </h2>
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
          Ücretsiz keşif ve 3D tasarım hizmeti. Tüm İstanbul ilçelerine hızlı teslimat ve profesyonel montaj.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/iletisim/" class="btn btn-primary px-8 py-3 text-sm font-bold uppercase tracking-widest">
            Teklif İste
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-green-600 text-white font-bold px-8 py-3 rounded-lg hover:bg-green-500 transition-all text-sm">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.588-5.946 0-6.556 5.332-11.891 11.893-11.891 3.181 0 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.481 8.414 0 6.556-5.332 11.892-11.893 11.892-1.99 0-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.591 5.405 0 9.801-4.398 9.801-9.805 0-5.403-4.395-9.804-9.801-9.804-5.408 0-9.805 4.398-9.805 9.804 0 2.229.615 4.317 1.784 6.149l-1.109 4.041 4.139-1.08z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${PHONE_TEL}`} class="inline-flex items-center justify-center gap-2 border border-primary text-primary font-bold px-8 py-3 rounded-lg hover:bg-primary hover:text-secondary transition-all text-sm">
            0531 618 16 72
          </a>
        </div>
      </div>

      <!-- SSS -->
      <div class="mt-16">
        <h2 class="font-heading font-bold text-2xl text-white mb-6 uppercase tracking-tight">
          Sıkça Sorulan <span class="text-primary">Sorular</span>
        </h2>
        <div class="space-y-4 max-w-4xl">
          {faq.map((item) => (
            <details class="glass-card p-5 group">
              <summary class="font-bold text-white cursor-pointer list-none flex justify-between items-center">
                {item.question}
                <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <p class="text-gray-300 mt-3 leading-relaxed">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>

    </div>
  </section>
</Layout>
