---
import Layout from '../layouts/Layout.astro';
import MapEmbed from '../components/common/MapEmbed.astro';
import { ADDRESS, ADDRESS_LOCALITY, EMAIL, PHONE_NUMBER, PHONE_TEL } from '../consts';
import { SERVICE_LABELS, getServiceLabel } from '../config/serviceLabels';

const title = "İletişim | A2 Reklam";
const description = "İstanbul'da tabela ve reklam çözümleri için bizimle iletişime geçin. Ücretsiz keşif ve teklif için formumuzu doldurabilir veya bizi arayabilirsiniz.";
---

<Layout
  title={title}
  description={description}
  lang="tr"
  whatsappTitle="İletişim"
  whatsappLocation={ADDRESS_LOCALITY}
  mobileCtaVariant="contact"
>
  <div class="relative py-24 bg-secondary overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="text-center mb-16">
        <h1 class="font-heading font-bold text-4xl md:text-6xl mb-6 text-white uppercase tracking-tight">
          BİZE <span class="text-primary">ULAŞIN</span>
        </h1>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg border-l-2 border-primary pl-4 inline-block">
          Projeniz hakkında konuşmaya hazır mısınız? Formu doldurun, size en kısa sürede dönüş yapalım.
        </p>
      </div>

      <div class="glass-card grid grid-cols-1 lg:grid-cols-2 gap-12 p-8 md:p-12">
        <!-- Contact Form -->
        <div>
          <form id="contact-form" class="space-y-6" data-track="lead-submit" data-lead-type="contact" data-lang="tr">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="form-label">Ad Soyad</label>
              <input type="text" name="fullName" autocomplete="name" class="form-input" placeholder="Adınız Soyadınız" required />
            </div>
              <div>
                <label class="form-label">E-posta</label>
                <input type="email" name="email" autocomplete="email" class="form-input" placeholder="ornek@mail.com" required />
              </div>
            </div>
            <div>
              <label class="form-label">Telefon</label>
              <input type="tel" name="phone" autocomplete="tel" class="form-input" placeholder="05XX XXX XX XX" required />
            </div>
            <div>
              <label class="form-label">Hizmet Türü</label>
              <select name="serviceType" class="form-select">
                {Object.keys(SERVICE_LABELS).map((slug) => (
                  <option value={slug}>{getServiceLabel(slug as keyof typeof SERVICE_LABELS, 'tr')}</option>
                ))}
                <option value="diger">Diğer</option>
              </select>
            </div>
            <div>
              <label class="form-label">Mesajınız</label>
              <textarea rows="4" name="message" class="form-input" placeholder="Projeniz detaylarını buraya yazabilirsiniz..."></textarea>
            </div>
            <button type="submit" class="w-full bg-primary text-secondary font-black py-4 rounded-lg hover:bg-white transition-all transform hover:-translate-y-1 shadow-lg shadow-primary/20 uppercase tracking-widest">
              GÖNDER
            </button>
            <p class="text-center text-gray-500 text-xs mt-4 px-6 leading-relaxed">
              Formu göndererek sizinle iletişime geçmemizi kabul etmiş olursunuz. Verileriniz KVKK kapsamında korunmaktadır.
            </p>
          </form>
        </div>

        <!-- Contact Info & Map -->
        <div class="space-y-6">
          <div class="space-y-3">
            <!-- Telefon -->
            <a href={`tel:${PHONE_TEL}`} data-track="call" data-lang="tr" class="flex items-center gap-4 glass-card p-4 hover:border-primary/30 transition-all group">
              <div class="w-11 h-11 bg-primary/20 rounded-xl flex items-center justify-center text-primary shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <h3 class="text-white font-bold text-sm">Telefon</h3>
                <span class="text-gray-400 group-hover:text-primary transition-colors text-sm">{PHONE_NUMBER}</span>
              </div>
            </a>
            <!-- E-posta -->
            <a href={`mailto:${EMAIL}`} class="flex items-center gap-4 glass-card p-4 hover:border-primary/30 transition-all group">
              <div class="w-11 h-11 bg-primary/20 rounded-xl flex items-center justify-center text-primary shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <h3 class="text-white font-bold text-sm">E-posta</h3>
                <span class="text-gray-400 group-hover:text-primary transition-colors text-sm">{EMAIL}</span>
              </div>
            </a>
            <!-- Adres -->
            <div class="flex items-start gap-4 glass-card p-4">
              <div class="w-11 h-11 bg-primary/20 rounded-xl flex items-center justify-center text-primary shrink-0 mt-0.5">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h3 class="text-white font-bold text-sm">Adres</h3>
                <p class="text-gray-400 text-sm leading-relaxed">{ADDRESS}</p>
              </div>
            </div>
          </div>

          <MapEmbed className="!h-52 md:!h-72" />
        </div>
      </div>
    </div>
  </div>

  <section class="py-10 bg-secondary border-t border-white/5">
    <div class="container mx-auto px-4 text-center">
      <p class="text-gray-400 text-sm">
        <a href="/istanbul-tabelaci/" class="text-primary hover:text-white transition-colors">39 İlçeye Tabela Hizmeti</a>
        &nbsp;·&nbsp;
        <a href="/sektorel/" class="text-primary hover:text-white transition-colors">20+ Sektöre Özel Tabela</a>
        &nbsp;·&nbsp;
        <a href="/hizmetler/" class="text-primary hover:text-white transition-colors">Tüm Hizmetlerimiz</a>
      </p>
    </div>
  </section>
</Layout>

<script>
  import '../scripts/contact-form';
</script>
